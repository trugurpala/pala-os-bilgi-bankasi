+import { buildAppState, buildSearchPack } from './bootstrap.js';
+
+export async function buildContextPack(db, query, { profile = 'bak' } = {}) {
+  const appState = await buildAppState(db, { profile, query });
+  const searchPack = await buildSearchPack(db, query);
+
+  return {
+    task: query,
+    profile,
+    route: appState.route,
+    nextActions: appState.nextActions,
+    searchPack,
+    appState,
+    standardsCount: appState.summary.total,
+    blockedCount: appState.summary.blocked,
+    sourceCardsCount: appState.sourceCards.length,
+    skillRegistryCount: appState.skillRegistrySummary.total,
+    recentEvents: appState.events,
+  };
+}
