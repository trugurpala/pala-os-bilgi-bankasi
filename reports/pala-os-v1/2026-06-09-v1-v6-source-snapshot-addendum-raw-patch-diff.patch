+              <tbody>
+                ${state.events.map((event) => `
+                  <tr>
+                    <td>${escapeHtml(event.kind)}</td>
+                    <td>${escapeHtml(event.message)}</td>
+                    <td>${escapeHtml(event.createdAt)}</td>
+                  </tr>
+                `).join('')}
+              </tbody>
+            </table>
+          </div>
+        </article>
+
+        <article id="doctrine" class="panel span-12">
+          <div class="section-head">
+            <div>
+              <h3>Reference Doctrine</h3>
+              <p>Bu ekran artik bos estetik denemesi degil. Hangi cevheri nereden alip hangi katmanda kullandigimiz acikca yaziliyor.</p>
+            </div>
+            <div class="mini-note">Primary upstream thinking</div>
+          </div>
+          <div class="table-wrap">
+            <table>
+              <thead>
+                <tr>
+                  <th>Reference</th>
+                  <th>Layer</th>
+                  <th>Status</th>
+                  <th>What we steal carefully</th>
+                </tr>
+              </thead>
+              <tbody>
+                ${REFERENCE_DOCTRINE.map((reference) => `
+                  <tr>
+                    <td>${escapeHtml(reference.name)}</td>
+                    <td>${escapeHtml(reference.layer)}</td>
+                    <td><span class="status-pill-mini ${reference.status === 'adopt' ? 'good' : 'neutral'}">${escapeHtml(reference.status)}</span></td>
+                    <td>${escapeHtml(reference.extract)}</td>
+                  </tr>
+                `).join('')}
+              </tbody>
+            </table>
+          </div>
+        </article>
+
+        <article class="panel span-12">
+          <details>
+            <summary>
+              <span>Full World Standards Matrix</span>
+              <span>${statusCounts.required ?? 0} required | ${statusCounts.recommended ?? 0} recommended | ${statusCounts.blocked ?? 0} blocked</span>
+            </summary>
+            <div class="details-body table-wrap">
+              <table>
+                <thead>
+                  <tr>
+                    <th>Status</th>
+                    <th>Standard</th>
+                    <th>Family</th>
+                    <th>Evidence</th>
+                    <th>Reason</th>
+                  </tr>
+                </thead>
+                <tbody>
+                  ${state.standards.map((standard) => `
+                    <tr id="family-${escapeHtml(familySlug(standard.family))}">
+                      <td><span class="status-pill-mini ${pillClass(standard.status)}">${escapeHtml(standard.status)}</span></td>
+                      <td>${escapeHtml(standard.title)}</td>
+                      <td>${escapeHtml(standard.family)}</td>
+                      <td>${standard.evidenceCount}</td>
+                      <td>${escapeHtml(standard.reason)}</td>
+                    </tr>
+                  `).join('')}
+                </tbody>
+              </table>
+            </div>
+          </details>
+        </article>
+      </section>
+
+      <div class="footer-note">
+        Last generated ${escapeHtml(state.generatedAt)}. Status summary: required ${statusCounts.required ?? 0}, recommended ${statusCounts.recommended ?? 0}, blocked ${statusCounts.blocked ?? 0}, not applicable ${statusCounts.not_applicable_with_reason ?? 0}. This deck now leans into a stronger command-radar language instead of a plain admin panel, while keeping the same no-fake-done evidence contract underneath.
+      </div>
+    </main>
+  </div>
+</body>
+</html>`;
+}
diff --git a/source-snapshots/raw/pala-os-v6/src/db.js b/source-snapshots/raw/pala-os-v6/src/db.js
new file mode 100644
index 0000000..9b9ef42
--- /dev/null
+++ b/source-snapshots/raw/pala-os-v6/src/db.js
@@ -0,0 +1,436 @@
+import { randomUUID } from 'node:crypto';
+import { DatabaseSync } from 'node:sqlite';
+import { DB_PATH } from './config.js';
+import { appendLedgerRecord } from './ledger.js';
+
+function nowIso() {
+  return new Date().toISOString();
+}
+
+export function openDatabase() {
+  const db = new DatabaseSync(DB_PATH);
+  db.exec('PRAGMA foreign_keys = ON;');
+  db.exec('PRAGMA busy_timeout = 5000;');
+  return db;
+}
+
+export function migrateDatabase(db) {
+  db.exec('PRAGMA foreign_keys = ON;');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS meta (
+      key TEXT PRIMARY KEY,
+      value TEXT NOT NULL,
+      updated_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS standards (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      family TEXT NOT NULL,
+      policy_state TEXT NOT NULL,
+      focus_json TEXT NOT NULL,
+      watchers_json TEXT NOT NULL,
+      created_at TEXT NOT NULL,
+      updated_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS evidence_items (
+      id TEXT PRIMARY KEY,
+      standard_id TEXT NOT NULL,
+      kind TEXT NOT NULL,
+      detail TEXT NOT NULL,
+      source TEXT NOT NULL,
+      created_at TEXT NOT NULL,
+      FOREIGN KEY (standard_id) REFERENCES standards (id)
+    );
+
+    CREATE TABLE IF NOT EXISTS source_cards (
+      id TEXT PRIMARY KEY,
+      origin_type TEXT NOT NULL,
+      origin_ref TEXT NOT NULL,
+      repo_full_name TEXT,
+      commit_sha TEXT,
+      license TEXT,
+      decision TEXT NOT NULL,
+      risk_level TEXT NOT NULL,
+      allowed_layer TEXT NOT NULL,
+      summary TEXT NOT NULL,
+      evidence_uri TEXT,
+      created_at TEXT NOT NULL,
+      updated_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS events (
+      id TEXT PRIMARY KEY,
+      kind TEXT NOT NULL,
+      message TEXT NOT NULL,
+      payload_json TEXT NOT NULL,
+      source TEXT NOT NULL,
+      created_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS job_runs (
+      id TEXT PRIMARY KEY,
+      job_name TEXT NOT NULL,
+      status TEXT NOT NULL,
+      detail TEXT NOT NULL,
+      started_at TEXT NOT NULL,
+      finished_at TEXT NOT NULL,
+      runtime_ms INTEGER NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS tool_usage (
+      id TEXT PRIMARY KEY,
+      tool_name TEXT NOT NULL,
+      purpose TEXT NOT NULL,
+      context_json TEXT NOT NULL,
+      tokens_estimated INTEGER NOT NULL,
+      created_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS gate_decisions (
+      id TEXT PRIMARY KEY,
+      gate_name TEXT NOT NULL,
+      decision TEXT NOT NULL,
+      reason TEXT NOT NULL,
+      context_json TEXT NOT NULL,
+      created_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS token_snapshots (
+      id TEXT PRIMARY KEY,
+      task_name TEXT NOT NULL,
+      planned_tokens INTEGER NOT NULL,
+      actual_tokens INTEGER NOT NULL,
+      notes TEXT NOT NULL,
+      created_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS dashboard_state (
+      name TEXT PRIMARY KEY,
+      value_json TEXT NOT NULL,
+      updated_at TEXT NOT NULL
+    );
+
+    CREATE TABLE IF NOT EXISTS runs (
+      id TEXT PRIMARY KEY,
+      command TEXT NOT NULL,
+      goal TEXT NOT NULL,
+      status TEXT NOT NULL,
+      started_at TEXT NOT NULL,
+      ended_at TEXT,
+      risk_level TEXT NOT NULL,
+      token_confidence TEXT NOT NULL,
+      message TEXT
+    );
+  `);
+
+  db.exec(`CREATE INDEX IF NOT EXISTS idx_evidence_standard_id ON evidence_items(standard_id);`);
+  db.exec(`CREATE INDEX IF NOT EXISTS idx_events_created_at ON events(created_at DESC);`);
+  db.exec(`CREATE INDEX IF NOT EXISTS idx_job_runs_started_at ON job_runs(started_at DESC);`);
+  db.exec(`CREATE INDEX IF NOT EXISTS idx_source_cards_created_at ON source_cards(created_at DESC);`);
+  db.exec(`CREATE INDEX IF NOT EXISTS idx_tool_usage_created_at ON tool_usage(created_at DESC);`);
+  db.exec(`CREATE INDEX IF NOT EXISTS idx_runs_started_at ON runs(started_at DESC);`);
+}
+
+export function getMeta(db, key) {
+  const row = db.prepare(`SELECT value FROM meta WHERE key = ?`).get(key);
+  return row ? row.value : null;
+}
+
+export function setMeta(db, key, value) {
+  const updatedAt = nowIso();
+  db.prepare(`
+    INSERT INTO meta (key, value, updated_at)
+    VALUES (?, ?, ?)
+    ON CONFLICT(key) DO UPDATE SET value = excluded.value, updated_at = excluded.updated_at
+  `).run(key, String(value), updatedAt);
+  return { key, value: String(value), updatedAt };
+}
+
+export function hasMeta(db, key) {
+  return getMeta(db, key) !== null;
+}
+
+export function seedStandards(db, standards) {
+  const statement = db.prepare(`
+    INSERT OR IGNORE INTO standards (
+      id, title, family, policy_state, focus_json, watchers_json, created_at, updated_at
+    ) VALUES (
+      @id, @title, @family, @policy_state, @focus_json, @watchers_json, @created_at, @updated_at
+    )
+  `);
+
+  const createdAt = nowIso();
+  for (const standard of standards) {
+    statement.run({
+      id: standard.id,
+      title: standard.title,
+      family: standard.family,
+      policy_state: standard.policyState,
+      focus_json: JSON.stringify(standard.focus),
+      watchers_json: JSON.stringify(standard.watchers),
+      created_at: createdAt,
+      updated_at: createdAt,
+    });
+  }
+}
+
+export function loadStandards(db) {
+  return db.prepare(`SELECT * FROM standards ORDER BY family, title`).all().map((row) => ({
+    id: row.id,
+    title: row.title,
+    family: row.family,
+    policyState: row.policy_state,
+    focus: JSON.parse(row.focus_json),
+    watchers: JSON.parse(row.watchers_json),
+    createdAt: row.created_at,
+    updatedAt: row.updated_at,
+  }));
+}
+
+export function loadEvidenceCounts(db) {
+  const rows = db.prepare(`
+    SELECT standard_id, COUNT(*) AS count
+    FROM evidence_items
+    GROUP BY standard_id
+  `).all();
+
+  return new Map(rows.map((row) => [row.standard_id, row.count]));
+}
+
+export function loadRecentEvents(db, limit = 12) {
+  return db.prepare(`SELECT * FROM events ORDER BY created_at DESC LIMIT ?`).all(limit).map((row) => ({
+    id: row.id,
+    kind: row.kind,
+    message: row.message,
+    payload: JSON.parse(row.payload_json),
+    source: row.source,
+    createdAt: row.created_at,
+  }));
+}
+
+export function loadRecentSourceCards(db, limit = 12) {
+  return db.prepare(`SELECT * FROM source_cards ORDER BY created_at DESC LIMIT ?`).all(limit);
+}
+
+export function loadRecentJobRuns(db, limit = 12) {
+  return db.prepare(`SELECT * FROM job_runs ORDER BY started_at DESC LIMIT ?`).all(limit);
+}
+
+export function loadRecentTokenSnapshots(db, limit = 5) {
+  return db.prepare(`SELECT * FROM token_snapshots ORDER BY created_at DESC LIMIT ?`).all(limit);
+}
+
+export function addEvidenceItem(db, { standardId, kind, detail, source }) {
+  const id = randomUUID();
+  const createdAt = nowIso();
+  db.prepare(`
+    INSERT INTO evidence_items (id, standard_id, kind, detail, source, created_at)
+    VALUES (?, ?, ?, ?, ?, ?)
+  `).run(id, standardId, kind, detail, source, createdAt);
+  return { id, standardId, kind, detail, source, createdAt };
+}
+
+export function addSourceCard(db, sourceCard) {
+  const id = sourceCard.id ?? randomUUID();
+  const createdAt = sourceCard.createdAt ?? nowIso();
+  const updatedAt = sourceCard.updatedAt ?? createdAt;
+
+  db.prepare(`
+    INSERT INTO source_cards (
+      id, origin_type, origin_ref, repo_full_name, commit_sha, license, decision,
+      risk_level, allowed_layer, summary, evidence_uri, created_at, updated_at
+    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+  `).run(
+    id,
+    sourceCard.originType,
+    sourceCard.originRef,
+    sourceCard.repoFullName ?? null,
+    sourceCard.commitSha ?? null,
+    sourceCard.license ?? null,
+    sourceCard.decision,
+    sourceCard.riskLevel,
+    sourceCard.allowedLayer,
+    sourceCard.summary,
+    sourceCard.evidenceUri ?? null,
+    createdAt,
+    updatedAt,
+  );
+
+  appendLedgerRecord({
+    type: 'source-card',
+    id,
+    originRef: sourceCard.originRef,
+    decision: sourceCard.decision,
+    riskLevel: sourceCard.riskLevel,
+    allowedLayer: sourceCard.allowedLayer,
+    createdAt,
+  });
+
+  return { ...sourceCard, id, createdAt, updatedAt };
+}
+
+export function addEvent(db, { kind, message, payload = {}, source = 'system' }) {
+  const id = randomUUID();
+  const createdAt = nowIso();
+  db.prepare(`
+    INSERT INTO events (id, kind, message, payload_json, source, created_at)
+    VALUES (?, ?, ?, ?, ?, ?)
+  `).run(id, kind, message, JSON.stringify(payload), source, createdAt);
+  appendLedgerRecord({
+    type: 'event',
+    id,
+    kind,
+    message,
+    payload,
+    source,
+    createdAt,
+  });
+  return { id, kind, message, payload, source, createdAt };
+}
+
+export function addJobRun(db, { jobName, status, detail, startedAt, finishedAt, runtimeMs }) {
+  const id = randomUUID();
+  db.prepare(`
+    INSERT INTO job_runs (id, job_name, status, detail, started_at, finished_at, runtime_ms)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `).run(id, jobName, status, detail, startedAt, finishedAt, runtimeMs);
+  appendLedgerRecord({
+    type: 'job-run',
+    id,
+    jobName,
+    status,
+    detail,
+    startedAt,
+    finishedAt,
+    runtimeMs,
+  });
+  return { id, jobName, status, detail, startedAt, finishedAt, runtimeMs };
+}
+
+export function addToolUsage(db, { toolName, purpose, context = {}, tokensEstimated = 0 }) {
+  const id = randomUUID();
+  const createdAt = nowIso();
+  db.prepare(`
+    INSERT INTO tool_usage (id, tool_name, purpose, context_json, tokens_estimated, created_at)
+    VALUES (?, ?, ?, ?, ?, ?)
+  `).run(id, toolName, purpose, JSON.stringify(context), tokensEstimated, createdAt);
+  appendLedgerRecord({
+    type: 'tool-usage',
+    id,
+    toolName,
+    purpose,
+    context,
+    tokensEstimated,
+    createdAt,
+  });
+  return { id, toolName, purpose, context, tokensEstimated, createdAt };
+}
+
+export function addGateDecision(db, { gateName, decision, reason, context = {} }) {
+  const id = randomUUID();
+  const createdAt = nowIso();
+  db.prepare(`
+    INSERT INTO gate_decisions (id, gate_name, decision, reason, context_json, created_at)
+    VALUES (?, ?, ?, ?, ?, ?)
+  `).run(id, gateName, decision, reason, JSON.stringify(context), createdAt);
+  appendLedgerRecord({
+    type: 'gate-decision',
+    id,
+    gateName,
+    decision,
+    reason,
+    context,
+    createdAt,
+  });
+  return { id, gateName, decision, reason, context, createdAt };
+}
+
+export function addTokenSnapshot(db, { taskName, plannedTokens, actualTokens, notes }) {
+  const id = randomUUID();
+  const createdAt = nowIso();
+  db.prepare(`
+    INSERT INTO token_snapshots (id, task_name, planned_tokens, actual_tokens, notes, created_at)
+    VALUES (?, ?, ?, ?, ?, ?)
+  `).run(id, taskName, plannedTokens, actualTokens, notes, createdAt);
+  appendLedgerRecord({
+    type: 'token-snapshot',
+    id,
+    taskName,
+    plannedTokens,
+    actualTokens,
+    notes,
+    createdAt,
+  });
+  return { id, taskName, plannedTokens, actualTokens, notes, createdAt };
+}
+
+export function startRun(db, { command, goal, riskLevel = 'medium', tokenConfidence = 'low' }) {
+  const id = randomUUID();
+  const startedAt = nowIso();
+  db.prepare(`
+    INSERT INTO runs (id, command, goal, status, started_at, ended_at, risk_level, token_confidence, message)
+    VALUES (?, ?, ?, ?, ?, NULL, ?, ?, NULL)
+  `).run(id, command, goal, 'started', startedAt, riskLevel, tokenConfidence);
+  appendLedgerRecord({
+    type: 'run',
+    id,
+    command,
+    goal,
+    status: 'started',
+    startedAt,
+    riskLevel,
+    tokenConfidence,
+  });
+  return { id, command, goal, status: 'started', startedAt, riskLevel, tokenConfidence };
+}
+
+export function finishRun(db, runId, { status, message = null } = {}) {
+  const endedAt = nowIso();
+  db.prepare(`
+    UPDATE runs
+    SET status = ?, ended_at = ?, message = ?
+    WHERE id = ?
+  `).run(status, endedAt, message, runId);
+  appendLedgerRecord({
+    type: 'run',
+    id: runId,
+    status,
+    endedAt,
+    message,
+  });
+  return { id: runId, status, endedAt, message };
+}
+
+export function loadRecentRuns(db, limit = 12) {
+  return db.prepare(`SELECT * FROM runs ORDER BY started_at DESC LIMIT ?`).all(limit);
+}
+
+export function saveDashboardState(db, name, value) {
+  const updatedAt = nowIso();
+  db.prepare(`
+    INSERT INTO dashboard_state (name, value_json, updated_at)
+    VALUES (?, ?, ?)
+    ON CONFLICT(name) DO UPDATE SET value_json = excluded.value_json, updated_at = excluded.updated_at
+  `).run(name, JSON.stringify(value), updatedAt);
+  return { name, value, updatedAt };
+}
+
+export function loadDashboardState(db, name = 'last') {
+  const row = db.prepare(`SELECT * FROM dashboard_state WHERE name = ?`).get(name);
+  if (!row) {
+    return null;
+  }
+
+  return {
+    name: row.name,
+    value: JSON.parse(row.value_json),
+    updatedAt: row.updated_at,
+  };
+}
+
+export function countLedgerRecords() {
+  return null;
+}
diff --git a/source-snapshots/raw/pala-os-v6/src/docker-smoke.js b/source-snapshots/raw/pala-os-v6/src/docker-smoke.js
new file mode 100644
index 0000000..ad71398
--- /dev/null
+++ b/source-snapshots/raw/pala-os-v6/src/docker-smoke.js
@@ -0,0 +1,175 @@
+import fs from 'node:fs/promises';
+import path from 'node:path';
+import { spawn } from 'node:child_process';
+import { DOCKER_EVIDENCE_DIR, ROOT_DIR } from './config.js';
+
+function runCommand(command, args, { cwd = ROOT_DIR, timeoutMs = 15000 } = {}) {
+  return new Promise((resolve) => {
+    const child = spawn(command, args, {
+      cwd,
+      stdio: ['ignore', 'pipe', 'pipe'],
+      windowsHide: true,
+    });
+
+    let stdout = '';
+    let stderr = '';
+    let timedOut = false;
+
+    const timer = setTimeout(() => {
+      timedOut = true;
+      child.kill('SIGTERM');
+    }, timeoutMs);
+
+    child.stdout.on('data', (chunk) => {
+      stdout += chunk.toString('utf8');
+    });
+
+    child.stderr.on('data', (chunk) => {
+      stderr += chunk.toString('utf8');
+    });
+
+    child.on('close', (code) => {
+      clearTimeout(timer);
+      resolve({
+        ok: !timedOut && code === 0,
+        code,
+        stdout,
+        stderr,
+        timedOut,
+      });
+    });
+  });
+}
+
+async function fetchHealth(url, timeoutMs = 10000) {
+  const controller = new AbortController();
+  const timer = setTimeout(() => controller.abort(), timeoutMs);
+
+  try {
+    const response = await fetch(url, { signal: controller.signal });
+    const text = await response.text();
+    return {
+      ok: response.ok,
+      status: response.status,
+      body: text,
+    };
+  } catch (error) {
+    return {
+      ok: false,
+      error: error instanceof Error ? error.message : String(error),
+    };
+  } finally {
+    clearTimeout(timer);
+  }
+}
+
+export async function runDockerSmoke() {
+  const timestamp = new Date().toISOString().replaceAll(':', '-');
+  const evidencePath = path.join(DOCKER_EVIDENCE_DIR, `docker-smoke-${timestamp}.json`);
+
+  const dockerVersion = await runCommand('docker', ['--version']);
+  const composeVersion = await runCommand('docker', ['compose', 'version']);
+
+  if (!dockerVersion.ok || !composeVersion.ok) {
+    const payload = {
+      ok: false,
+      status: 'NOT_USED_WITH_REASON',
+      reason: 'docker or docker compose unavailable',
+      dockerVersion,
+      composeVersion,
+    };
+    await fs.writeFile(evidencePath, `${JSON.stringify(payload, null, 2)}\n`, 'utf8');
+    return { ...payload, evidencePath };
+  }
+
+  const composeConfig = await runCommand('docker', ['compose', '-f', 'compose.yaml', 'config']);
+  const composeServices = await runCommand('docker', ['compose', '-f', 'compose.yaml', 'config', '--services']);
+  const composeBuild = await runCommand(
+    'docker',
+    ['compose', '-f', 'compose.yaml', 'build', 'pala-v6-dashboard'],
+    { timeoutMs: 120000 },
+  );
+
+  const services = composeServices.stdout
+    .split(/\r?\n/)
+    .map((line) => line.trim())
+    .filter(Boolean);
+
+  let composeUp = {
+    ok: false,
+    code: null,
+    stderr: '',
+  };
+  let healthProbe = {
+    ok: false,
+    error: 'health probe not attempted',
+  };
+  let composeDown = {
+    ok: false,
+    code: null,
+    stderr: '',
+  };
+
+  if (composeBuild.ok) {
+    composeUp = await runCommand(
+      'docker',
+      ['compose', '-f', 'compose.yaml', 'up', '-d', 'pala-v6-dashboard'],
+      { timeoutMs: 60000 },
+    );
+
+    if (composeUp.ok) {
+      await new Promise((resolve) => setTimeout(resolve, 5000));
+      healthProbe = await fetchHealth('http://127.0.0.1:8787/api/health', 10000);
+    }
+
+    composeDown = await runCommand(
+      'docker',
+      ['compose', '-f', 'compose.yaml', 'down'],
+      { timeoutMs: 60000 },
+    );
+  }
+
+  const fullSmokeOk = composeConfig.ok && composeServices.ok && composeBuild.ok && composeUp.ok && healthProbe.ok;
+
+  const payload = {
+    ok: fullSmokeOk,
+    status: fullSmokeOk ? 'PARTIAL' : composeConfig.ok && composeServices.ok ? 'PARTIAL' : 'BLOCKED',
+    reason: fullSmokeOk
+      ? 'compose parsed, built, started dashboard, passed local health probe, and cleaned up'
+      : composeConfig.ok && composeServices.ok
+        ? 'compose parsed and services resolved; build/up/health was partial or failed'
+        : 'compose smoke failed',
+    dockerVersion,
+    composeVersion,
+    composeConfig: {
+      ok: composeConfig.ok,
+      code: composeConfig.code,
+      stderr: composeConfig.stderr,
+    },
+    composeServices: {
+      ok: composeServices.ok,
+      code: composeServices.code,
+      services,
+      stderr: composeServices.stderr,
+    },
+    composeBuild: {
+      ok: composeBuild.ok,
+      code: composeBuild.code,
+      stderr: composeBuild.stderr,
+    },
+    composeUp: {
+      ok: composeUp.ok,
+      code: composeUp.code,
+      stderr: composeUp.stderr,
+    },
+    healthProbe,
+    composeDown: {
+      ok: composeDown.ok,
+      code: composeDown.code,
+      stderr: composeDown.stderr,
+    },
+  };
+
+  await fs.writeFile(evidencePath, `${JSON.stringify(payload, null, 2)}\n`, 'utf8');
+  return { ...payload, evidencePath };
+}
