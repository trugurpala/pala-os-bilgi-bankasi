+    const key = token.slice(2).replaceAll('-', '');
+    const next = rest[index + 1];
+    if (next && !next.startsWith('--')) {
+      flags[key] = next;
+      index += 1;
+    } else {
+      flags[key] = true;
+    }
+  }
+
+  return flags;
