+        secrets: 'forbidden',
+        destructive_ops: false,
+      },
+      risk: 'medium',
+      decision: 'ADAPT',
+      source_ref: 'docs/inheritance-backlog.json',
+    },
+    {
+      name: 'token-economy-pack',
+      domain: 'universal',
+      status: 'import_later',
+      path: 'src/context-pack.js',
+      tier: 'support',
+      compatibility: ['codex', 'cursor', 'chatgpt'],
+      permission_budget: {
