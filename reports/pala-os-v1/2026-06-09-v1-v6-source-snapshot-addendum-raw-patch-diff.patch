@@ -0,0 +1,130 @@
+import fs from 'node:fs/promises';
+import { BENCHMARK_STATE_PATH } from './config.js';
+
+export const BENCHMARK_SEED = {
+  version: 1,
+  status: 'RELEASE_BLOCKED',
+  generated_at: null,
+  categories: [
+    {
+      id: 'latency',
+      title: 'Latency',
+      status: 'partial',
+      evidence_count: 0,
+      note: 'No fixture-backed timing suite yet; local estimates only.',
+    },
+    {
+      id: 'evidence-completeness',
+      title: 'Evidence Completeness',
+      status: 'partial',
+      evidence_count: 0,
+      note: 'Coverage is inferred from source cards, ledger, and standards.',
+    },
+    {
+      id: 'token-pressure',
+      title: 'Token Pressure',
+      status: 'partial',
+      evidence_count: 0,
+      note: 'Token accounting is still estimate-driven.',
+    },
+    {
+      id: 'cross-agent',
+      title: 'Cross-Agent Comparability',
+      status: 'blocked',
+      evidence_count: 0,
+      note: 'No comparable Cursor/ChatGPT run set has been captured yet.',
+    },
+  ],
+  last_run: null,
+};
+
+export async function ensureBenchmarkState() {
+  try {
+    await fs.access(BENCHMARK_STATE_PATH);
+  } catch {
+    const seeded = {
+      ...BENCHMARK_SEED,
+      generated_at: new Date().toISOString(),
+    };
+    await fs.writeFile(BENCHMARK_STATE_PATH, `${JSON.stringify(seeded, null, 2)}\n`, 'utf8');
+  }
+}
+
+export async function loadBenchmarkState() {
+  await ensureBenchmarkState();
+  const content = await fs.readFile(BENCHMARK_STATE_PATH, 'utf8');
+  return JSON.parse(content);
+}
+
+export async function runBenchmarkSnapshot({ appState }) {
+  const evidenceCompleteness = Math.min(
+    100,
+    Math.round(((appState.sourceCards.length + appState.ledger.length + appState.summary.satisfied) / Math.max(1, appState.summary.total)) * 100),
+  );
+
+  const tokenPressureScore = Math.min(
+    100,
+    Math.round((appState.tokenBudget.actualTokens / Math.max(1, appState.tokenBudget.plannedTokens)) * 100),
+  );
+
+  const snapshot = {
+    version: 1,
+    status: 'RELEASE_BLOCKED',
+    generated_at: new Date().toISOString(),
+    categories: [
+      {
+        id: 'latency',
+        title: 'Latency',
+        status: 'partial',
+        evidence_count: appState.runs.length,
+        score: 0,
+        note: 'No fixture-backed timing suite yet; runtime only records command/job counts.',
+      },
+      {
+        id: 'evidence-completeness',
+        title: 'Evidence Completeness',
+        status: evidenceCompleteness > 0 ? 'partial' : 'blocked',
+        evidence_count: appState.ledger.length,
+        score: evidenceCompleteness,
+        note: `${appState.sourceCards.length} source cards, ${appState.ledger.length} ledger rows, ${appState.summary.satisfied} satisfied standards.`,
+      },
+      {
+        id: 'token-pressure',
+        title: 'Token Pressure',
+        status: 'partial',
+        evidence_count: appState.tokenSnapshots.length,
+        score: tokenPressureScore,
+        note: `Actual ${appState.tokenBudget.actualTokens} vs planned ${appState.tokenBudget.plannedTokens}.`,
+      },
+      {
+        id: 'cross-agent',
+        title: 'Cross-Agent Comparability',
+        status: 'blocked',
+        evidence_count: appState.skillRegistrySummary.total,
+        score: 0,
+        note: 'Registry lists multi-agent compatibility, but comparable run corpus is missing.',
+      },
+    ],
+    last_run: {
+      route: appState.route,
+      blocked_required: appState.summary.blocked,
+      skill_registry_total: appState.skillRegistrySummary.total,
+      court_decision: appState.court.decision,
+    },
+  };
+
+  await fs.writeFile(BENCHMARK_STATE_PATH, `${JSON.stringify(snapshot, null, 2)}\n`, 'utf8');
+  return snapshot;
+}
+
+export function summarizeBenchmarkState(benchmarkState) {
+  const byStatus = {};
+  for (const category of benchmarkState.categories ?? []) {
+    byStatus[category.status] = (byStatus[category.status] ?? 0) + 1;
+  }
+
+  return {
+    total: benchmarkState.categories?.length ?? 0,
+    byStatus,
+  };
+}
