@@ -0,0 +1,274 @@
+import fs from 'node:fs/promises';
+import { spawn } from 'node:child_process';
+import {
+  BATTALIONS_PATH,
+  DASHBOARD_STATE_PATH,
+  POLICY_PATH,
+  ROOT_DIR,
+  ensureAppDirs,
+} from './config.js';
+import {
+  addEvent,
+  addGateDecision,
+  addJobRun,
+  addSourceCard,
+  addTokenSnapshot,
+  addToolUsage,
+  getMeta,
+  loadEvidenceCounts,
+  loadRecentEvents,
+  loadRecentJobRuns,
+  loadRecentRuns,
+  loadRecentSourceCards,
+  loadRecentTokenSnapshots,
+  loadStandards,
+  migrateDatabase,
+  openDatabase,
+  saveDashboardState,
+  seedStandards,
+  setMeta,
+} from './db.js';
+import { catalogSeed, STANDARD_CATALOG, searchStandards } from './standards.js';
+import { battalionCatalog, EVIDENCE_BATTALIONS } from './evidence-battalions.js';
+import { evaluateCourt, evaluateStandards, suggestNextActions, summarizeEvaluations, summarizeJobs } from './policy.js';
+import { getGithubBridgeStatus } from './github.js';
+import { renderDashboardPage } from './dashboard.js';
+import { readLedgerRecords } from './ledger.js';
+import {
+  ensureSeedSkillRegistry,
+  listRegistrySkills,
+  loadSeedSkillRegistry,
+  summarizeSkillRegistry,
+} from './skill-registry.js';
+import { ensureBenchmarkState, loadBenchmarkState, summarizeBenchmarkState } from './benchmark.js';
+
+export async function bootstrapApp() {
+  await ensureAppDirs();
+  const db = openDatabase();
+  migrateDatabase(db);
+  seedStandards(db, STANDARD_CATALOG);
+
+  await fs.writeFile(POLICY_PATH, `${JSON.stringify(catalogSeed(), null, 2)}\n`, 'utf8');
+  await fs.writeFile(BATTALIONS_PATH, `${JSON.stringify(battalionCatalog(), null, 2)}\n`, 'utf8');
+  await ensureSeedSkillRegistry();
+  await ensureBenchmarkState();
+
+  if (getMeta(db, 'bootstrapped') !== '1') {
+    addEvent(db, {
+      kind: 'bootstrap',
+      message: 'Pala OS V6 bootstrap complete',
+      payload: {
+        standards: STANDARD_CATALOG.length,
+        rootDir: ROOT_DIR,
+      },
+      source: 'bootstrap',
+    });
+    setMeta(db, 'bootstrapped', '1');
+  }
+
+  return { db };
+}
+
+function estimateTokenSnapshot(profile, query, standards, events) {
+  const plannedTokens = 120 + query.length * 4 + standards.length * 2;
+  const actualTokens = plannedTokens + Math.max(0, events.length * 3);
+
+  return {
+    taskName: `profile:${profile}`,
+    plannedTokens,
+    actualTokens,
+    notes: 'Estimated before explicit token accounting is available',
+    createdAt: new Date().toISOString(),
+  };
+}
+
+export async function buildAppState(db, { profile = 'dashboard', query = '' } = {}) {
+  const standards = loadStandards(db);
+  const evidenceCounts = loadEvidenceCounts(db);
+  const evaluatedStandards = evaluateStandards(standards, evidenceCounts, { profile, query });
+  const events = loadRecentEvents(db, 12);
+  const sourceCards = loadRecentSourceCards(db, 12);
+  const jobRuns = loadRecentJobRuns(db, 12);
+  const runs = loadRecentRuns(db, 12);
+  const tokenSnapshots = loadRecentTokenSnapshots(db, 5);
+  const ledger = readLedgerRecords(250);
+  const github = await getGithubBridgeStatus();
+  const skillRegistry = await loadSeedSkillRegistry();
+  const skillRegistrySummary = summarizeSkillRegistry(skillRegistry);
+  const benchmarkState = await loadBenchmarkState();
+  const benchmarkSummary = summarizeBenchmarkState(benchmarkState);
+  const summary = summarizeEvaluations(evaluatedStandards);
+  const jobSummary = summarizeJobs(jobRuns);
+  const blockedStandards = evaluatedStandards.filter((standard) => standard.status === 'blocked');
+  const route = blockedStandards.length > 0 ? 'court' : sourceCards.length === 0 ? 'sources' : 'system';
+  const tokenBudget = tokenSnapshots[0] ?? estimateTokenSnapshot(profile, query, evaluatedStandards, events);
+  const court = evaluateCourt({
+    summary,
+    sourceCards,
+    runs,
+    ledger,
+  });
+
+  const state = {
+    app: 'Pala OS V6',
+    rootDir: ROOT_DIR,
+    profile,
+    query,
+    route,
+    github,
+    skillRegistry,
+    skillRegistrySummary,
+    benchmarkState,
+    benchmarkSummary,
+    skillRegistryViews: {
+      list: listRegistrySkills(skillRegistry),
+      core: listRegistrySkills(skillRegistry, { status: 'draft' }).slice(0, 6),
+    },
+    summary: {
+      ...summary,
+      blocked: summary.byStatus.blocked ?? 0,
+      recommended: summary.byStatus.recommended ?? 0,
+      required: summary.byStatus.required ?? 0,
+      notApplicable: summary.byStatus.not_applicable_with_reason ?? 0,
+    },
+    jobSummary,
+    standards: evaluatedStandards,
+    events,
+    sourceCards,
+    jobRuns,
+    runs,
+    tokenSnapshots,
+    ledger,
+    tokenBudget,
+    court,
+    nextActions: suggestNextActions({
+      summary: {
+        blocked: summary.byStatus.blocked ?? 0,
+      },
+      sourceCards,
+      github,
+    }),
+    generatedAt: new Date().toISOString(),
+  };
+
