@@ -0,0 +1,125 @@
+const PROFILE_FOCUS = {
+  bootstrap: new Set(['governance', 'security', 'runtime', 'philosophy', 'github']),
+  dashboard: new Set(['governance', 'security', 'runtime', 'philosophy', 'github']),
+  ingest: new Set(['governance', 'security', 'supply-chain', 'application', 'ai', 'metrics', 'github']),
+  release: new Set(['governance', 'security', 'supply-chain', 'runtime', 'application', 'ai', 'metrics', 'philosophy', 'github']),
+  court: new Set(['governance', 'security', 'supply-chain', 'runtime', 'application', 'ai', 'metrics', 'philosophy', 'github']),
+  cron: new Set(['governance', 'security', 'supply-chain', 'runtime', 'philosophy', 'github']),
+  bak: new Set(['governance', 'security', 'supply-chain', 'runtime', 'application', 'ai', 'metrics', 'philosophy', 'github']),
+};
+
+export function evaluateStandards(standards, evidenceCounts, { profile = 'dashboard', query = '' } = {}) {
+  const focus = PROFILE_FOCUS[profile] ?? PROFILE_FOCUS.dashboard;
+  const needle = String(query ?? '').trim().toLowerCase();
+
+  return standards
+    .filter((standard) => {
+      if (!needle) {
+        return true;
+      }
+
+      const haystack = [standard.id, standard.title, standard.family, ...standard.focus].join(' ').toLowerCase();
+      return haystack.includes(needle);
+    })
+    .map((standard) => {
+      const applicable = standard.focus.some((tag) => focus.has(tag));
+      const evidenceCount = evidenceCounts.get(standard.id) ?? 0;
+      let status;
+      let satisfied = false;
+      let reason = '';
+
+      if (!applicable) {
+        status = 'not_applicable_with_reason';
+        reason = `outside ${profile} focus`;
+      } else if (standard.policyState === 'required') {
+        status = evidenceCount > 0 ? 'required' : 'blocked';
+        satisfied = evidenceCount > 0;
+        reason = evidenceCount > 0 ? 'evidence present' : 'evidence missing';
+      } else {
+        status = 'recommended';
+        satisfied = evidenceCount > 0;
+        reason = evidenceCount > 0 ? 'evidence present' : 'recommended; evidence pending';
+      }
+
+      return {
+        ...standard,
+        status,
+        satisfied,
+        reason,
+        evidenceCount,
+      };
+    });
+}
+
+export function summarizeEvaluations(rows) {
+  return rows.reduce(
+    (summary, row) => {
+      summary.total += 1;
+      summary.byStatus[row.status] = (summary.byStatus[row.status] ?? 0) + 1;
+      if (row.satisfied) {
+        summary.satisfied += 1;
+      }
+      return summary;
+    },
+    {
+      total: 0,
+      satisfied: 0,
+      byStatus: {},
+    },
+  );
+}
+
+export function summarizeJobs(jobRuns) {
+  return jobRuns.reduce(
+    (summary, jobRun) => {
+      summary.total += 1;
+      summary.byStatus[jobRun.status] = (summary.byStatus[jobRun.status] ?? 0) + 1;
+      return summary;
+    },
+    {
+      total: 0,
+      byStatus: {},
+    },
+  );
+}
+
+export function evaluateCourt({ summary, sourceCards, runs, ledger }) {
+  const ownerApproved = process.env.PALA_OWNER_APPROVED === '1';
+  const blockedRequired = summary.byStatus.blocked ?? summary.blocked ?? 0;
+  const evidencePressure = sourceCards.length === 0 ? 'source cards missing' : 'source cards present';
+  const ledgerPressure = Array.isArray(ledger) && ledger.length === 0 ? 'ledger empty' : 'ledger has records';
+  const baseReason = ownerApproved
+    ? 'owner approval present'
+    : 'owner approval missing';
+
+  return {
+    decision: 'RELEASE_BLOCKED',
+    ownerApproved,
+    reason: `${baseReason}; ${blockedRequired} required standard(s) still blocked; ${evidencePressure}; ${ledgerPressure}`,
+    blockedRequired,
+    runCount: runs?.length ?? 0,
+    evidenceCount: sourceCards.length,
+  };
+}
+
+export function suggestNextActions(appState) {
+  const actions = [];
+
+  if (appState.summary.blocked > 0) {
+    actions.push('Open court and resolve blocked required standards first.');
+  }
+
+  if (appState.sourceCards.length === 0) {
+    actions.push('Create the first source card before importing any external repo.');
+  }
+
+  if (!appState.github.configured) {
+    actions.push('Connect GitHub credentials before attempting sync.');
+  }
+
+  if (actions.length === 0) {
+    actions.push('Run cron and capture evidence before the next change.');
+  }
+
+  return actions;
+}
diff --git a/source-snapshots/raw/pala-os-v6/src/screenshot.js b/source-snapshots/raw/pala-os-v6/src/screenshot.js
