@@ -0,0 +1,92 @@
+import fs from 'node:fs/promises';
+import { DASHBOARD_STATE_PATH, LEDGER_PATH, POLICY_PATH, ROOT_DIR, SEED_SKILLS_PATH, SKILLS_DIR } from './config.js';
+import { loadDashboardState } from './db.js';
+import { readLedgerRecords } from './ledger.js';
+import { buildRegistryHealth, getRegistrySkill, listRegistrySkills, loadSeedSkillRegistry, summarizeSkillRegistry } from './skill-registry.js';
+
+async function pathExists(targetPath) {
+  try {
+    await fs.access(targetPath);
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+export async function palaHealth(db) {
+  const registry = await loadSeedSkillRegistry();
+  const dashboardState = loadDashboardState(db);
+  const ledgerRecords = readLedgerRecords(50);
+  const registryExists = await pathExists(SEED_SKILLS_PATH);
+  const skillsRootReachable = await pathExists(SKILLS_DIR);
+  const ruleFileReachable = await pathExists(POLICY_PATH);
+  const ledgerReachable = await pathExists(LEDGER_PATH);
+  const dashboardStateReachable = await pathExists(DASHBOARD_STATE_PATH);
+  const blockedRequiredCount = dashboardState?.value?.summary?.blocked ?? null;
+  const court = dashboardState?.value?.court ?? {
+    decision: 'RELEASE_BLOCKED',
+    reason: 'dashboard state missing; default court remains blocked',
+  };
+
+  return {
+    ok: true,
+    status: registry.status ?? 'unknown',
+    rootDir: ROOT_DIR,
+    registry: {
+      ...buildRegistryHealth(registry),
+      exists: registryExists,
+      parse_ok: true,
+    },
+    skills_root: {
+      reachable: skillsRootReachable,
+      path: SKILLS_DIR,
+    },
+    source_court_rules: {
+      reachable: ruleFileReachable,
+      path: POLICY_PATH,
+    },
+    ledger: {
+      reachable: ledgerReachable,
+      path: LEDGER_PATH,
+      count: ledgerRecords.length,
+    },
+    dashboard_state: {
+      reachable: dashboardStateReachable,
+      path: DASHBOARD_STATE_PATH,
+      present: Boolean(dashboardState),
+    },
+    court,
+    blocked_required_count: blockedRequiredCount,
+    release_state: court.decision ?? 'RELEASE_BLOCKED',
+  };
+}
+
+export async function palaListSkills(filters = {}) {
+  const registry = await loadSeedSkillRegistry();
+  return {
+    ok: true,
+    registry: buildRegistryHealth(registry),
+    summary: summarizeSkillRegistry(registry),
+    skills: listRegistrySkills(registry, filters),
+  };
+}
+
+export async function palaGetSkill(name) {
+  const registry = await loadSeedSkillRegistry();
+  const skill = getRegistrySkill(registry, name);
+  return {
+    ok: Boolean(skill),
+    registry: buildRegistryHealth(registry),
+    skill,
+  };
+}
+
+export async function palaSearchSkills(filters = {}) {
+  const registry = await loadSeedSkillRegistry();
+  return {
+    ok: true,
+    registry: buildRegistryHealth(registry),
+    query: String(filters.query ?? ''),
+    skills: listRegistrySkills(registry, filters),
+  };
+}
