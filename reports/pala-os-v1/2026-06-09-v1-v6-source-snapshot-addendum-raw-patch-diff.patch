+
+on:
+  push:
+  pull_request:
+  workflow_dispatch:
+  schedule:
+    - cron: '17 2 * * *'
+
+jobs:
+  test:
+    runs-on: windows-latest
+    env:
+      PALA_OPEN_BROWSER: '0'
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
+        with:
+          node-version: '24.14.1'
+      - name: Bootstrap app
+        run: node src/cli.js bootstrap
+      - name: Run tests
+        run: node --test
+      - name: Capture status
+        run: node src/cli.js status
+
+  nightly-cron:
+    if: github.event_name == 'schedule'
+    runs-on: windows-latest
+    env:
+      PALA_OPEN_BROWSER: '0'
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
+        with:
+          node-version: '24.14.1'
+      - name: Bootstrap app
+        run: node src/cli.js bootstrap
+      - name: Run local cron cycle
+        run: node src/cli.js cron run
+      - name: Read back dashboard state
+        run: node src/cli.js bak "nightly cron"
