@@ -0,0 +1,129 @@
+import fs from 'node:fs/promises';
+import path from 'node:path';
+import { ROOT_DIR } from './config.js';
+import { addEvent } from './db.js';
+
+function extractGithubRepoFromUrl(remoteUrl) {
+  const value = String(remoteUrl ?? '').trim();
+  if (!value) {
+    return null;
+  }
+
+  const httpsMatch = value.match(/github\.com[/:]([^/]+\/[^/.]+)(?:\.git)?$/i);
+  if (httpsMatch) {
+    return httpsMatch[1];
+  }
+
+  return null;
+}
+
+async function detectRepoFromGitConfig() {
+  try {
+    const gitConfigPath = path.join(ROOT_DIR, '.git', 'config');
+    const content = await fs.readFile(gitConfigPath, 'utf8');
+    const originBlock = content.match(/\[remote "origin"\]([\s\S]*?)(?=\n\[|$)/);
+    if (!originBlock) {
+      return null;
+    }
+
+    const urlMatch = originBlock[1].match(/url\s*=\s*(.+)/);
+    if (!urlMatch) {
+      return null;
+    }
+
+    return extractGithubRepoFromUrl(urlMatch[1]);
+  } catch {
+    return null;
+  }
+}
+
+export async function getGithubBridgeStatus() {
+  const tokenPresent = Boolean(process.env.GITHUB_TOKEN);
+  const envRepo = String(process.env.GITHUB_REPO ?? '').trim();
+  const detectedRepo = envRepo || await detectRepoFromGitConfig();
+  const repo = detectedRepo ? detectedRepo.trim() : '';
+  const hasRepo = repo.length > 0;
+  const configured = tokenPresent && hasRepo;
+  const detectedOnly = !tokenPresent && hasRepo;
+
+  return {
+    configured,
+    detectedOnly,
+    tokenPresent,
+    repo: repo || null,
+    status: configured ? 'connected' : detectedOnly ? 'detected' : 'disconnected',
+    reason: configured
+      ? 'GitHub bridge configured'
+      : detectedOnly
+        ? 'Repo auto-detected from git origin; set GITHUB_TOKEN for authenticated API reads'
+        : 'Set GITHUB_TOKEN and GITHUB_REPO',
+  };
+}
+
+export async function syncGithubBridge(db) {
+  const bridge = await getGithubBridgeStatus();
+
+  if (!bridge.repo) {
+    const event = addEvent(db, {
+      kind: 'github-sync',
+      message: 'GitHub bridge not configured',
+      payload: bridge,
+      source: 'github-bridge',
+    });
+    return { bridge, event, ok: false };
+  }
+
+  if (!bridge.tokenPresent) {
+    const payload = {
+      ok: false,
+      mode: 'detected-only',
+      repo: bridge.repo,
+      reason: bridge.reason,
+    };
+    const event = addEvent(db, {
+      kind: 'github-sync',
+      message: 'GitHub repo detected but token missing',
+      payload,
+      source: 'github-bridge',
+    });
+    return { bridge, event, ...payload };
+  }
+
+  try {
+    const response = await fetch(`https://api.github.com/repos/${bridge.repo}`, {
+      headers: {
+        accept: 'application/vnd.github+json',
+        'user-agent': 'pala-os-v6',
+        authorization: `Bearer ${process.env.GITHUB_TOKEN}`,
+        'x-github-api-version': '2022-11-28',
+      },
+    });
+
+    const payload = await response.json();
+    const event = addEvent(db, {
+      kind: 'github-sync',
+      message: response.ok ? 'GitHub bridge synced' : 'GitHub bridge sync failed',
+      payload: {
+        ok: response.ok,
+        status: response.status,
+        repo: bridge.repo,
+        payload,
+      },
+      source: 'github-bridge',
+    });
+
+    return { bridge, event, ok: response.ok, status: response.status, payload };
+  } catch (error) {
+    const event = addEvent(db, {
+      kind: 'github-sync',
+      message: 'GitHub bridge sync failed',
+      payload: {
+        repo: bridge.repo,
+        error: error instanceof Error ? error.message : String(error),
+      },
+      source: 'github-bridge',
+    });
+
+    return { bridge, event, ok: false, error: error instanceof Error ? error.message : String(error) };
+  }
+}
