+import http from 'node:http';
+import { URL } from 'node:url';
+import { DEFAULT_PORT } from './config.js';
+import { buildAppState, openUrl, renderDashboardPage } from './bootstrap.js';
+import { loadDashboardState, loadRecentEvents, loadRecentRuns, loadRecentSourceCards, loadRecentTokenSnapshots, loadStandards } from './db.js';
+import { readLedgerRecords } from './ledger.js';
+
+function readRequestBody(request) {
+  return new Promise((resolve, reject) => {
+    const chunks = [];
+    request.on('data', (chunk) => chunks.push(chunk));
+    request.on('end', () => resolve(Buffer.concat(chunks).toString('utf8')));
+    request.on('error', reject);
+  });
+}
+
+export function createAppServer({ db, openBrowser = false, port = DEFAULT_PORT } = {}) {
+  const server = http.createServer(async (request, response) => {
+    const url = new URL(request.url ?? '/', `http://${request.headers.host ?? 'localhost'}`);
+
+    try {
+      if (request.method === 'GET' && url.pathname === '/') {
+        const state = await buildAppState(db, {
+          profile: 'dashboard',
+          query: url.searchParams.get('q') ?? '',
+        });
+        const html = renderDashboardPage(state);
+        response.writeHead(200, { 'content-type': 'text/html; charset=utf-8' });
+        response.end(html);
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/state') {
+        const state = await buildAppState(db, {
+          profile: url.searchParams.get('profile') ?? 'dashboard',
+          query: url.searchParams.get('q') ?? '',
+        });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify(state, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/health') {
+        const state = await buildAppState(db, {
+          profile: url.searchParams.get('profile') ?? 'dashboard',
+          query: url.searchParams.get('q') ?? '',
+        });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          app: state.app,
+          route: state.route,
+          court: state.court,
+          db: Boolean(db),
+          ledgerCount: state.ledger.length,
+          sourceCardCount: state.sourceCards.length,
+          blocked: state.summary.blocked,
+          skillRegistryCount: state.skillRegistrySummary.total,
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/db') {
+        const state = await buildAppState(db, { profile: 'dashboard' });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          tables: {
+            standards: state.summary.total,
+            events: state.events.length,
+            runs: state.runs.length,
+            sourceCards: state.sourceCards.length,
+            tokenSnapshots: state.tokenSnapshots.length,
+            skills: state.skillRegistrySummary.total,
+          },
+          dashboard: loadDashboardState(db),
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/ledger') {
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          path: '/.pala/ledger/events.jsonl',
+          records: readLedgerRecords(250),
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/evidence') {
+        const state = await buildAppState(db, { profile: 'dashboard' });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          standards: state.standards,
+          sourceCards: state.sourceCards,
+          tokenSnapshots: state.tokenSnapshots,
+          events: state.events,
+          skillRegistrySummary: state.skillRegistrySummary,
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/benchmark') {
+        const state = await buildAppState(db, { profile: 'dashboard' });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          summary: state.benchmarkSummary,
+          benchmark: state.benchmarkState,
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/screenshots') {
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          screenshots: [],
+          note: 'placeholder until screenshot evidence is captured',
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/sources') {
+        const state = await buildAppState(db, { profile: 'dashboard' });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          sourceCards: state.sourceCards,
+          recentRuns: state.runs,
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/skills') {
+        const state = await buildAppState(db, { profile: 'dashboard' });
+        const query = url.searchParams.get('q') ?? '';
+        const domain = url.searchParams.get('domain') ?? '';
+        const status = url.searchParams.get('status') ?? '';
+        const compatibility = url.searchParams.get('compatibility') ?? '';
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          registry: {
+            version: state.skillRegistry.version,
+            status: state.skillRegistry.status,
+            generated_from: state.skillRegistry.generated_from,
+          },
+          summary: state.skillRegistrySummary,
+          filters: {
+            q: query,
+            domain,
+            status,
+            compatibility,
+          },
+          skills: query || domain || status || compatibility
+            ? state.skillRegistryViews.list.filter((skill) => {
+              const queryLower = query.toLowerCase();
+              const domainLower = domain.toLowerCase();
+              const statusLower = status.toLowerCase();
+              const compatibilityLower = compatibility.toLowerCase();
+
+              if (domainLower && skill.domain.toLowerCase() !== domainLower) return false;
+              if (statusLower && skill.status.toLowerCase() !== statusLower) return false;
+              if (compatibilityLower && !skill.compatibility.some((item) => String(item).toLowerCase() === compatibilityLower)) return false;
+              if (!queryLower) return true;
+
+              return [
+                skill.name,
+                skill.domain,
+                skill.path,
+                skill.tier,
+                skill.decision,
+                skill.source_ref,
+                ...(skill.triggers ?? []),
+              ].some((item) => String(item ?? '').toLowerCase().includes(queryLower));
+            })
+            : state.skillRegistryViews.list,
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/court') {
+        const state = await buildAppState(db, { profile: 'court' });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          ...state.court,
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'GET' && url.pathname === '/api/tools') {
+        const state = await buildAppState(db, { profile: 'dashboard' });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({
+          ok: true,
+          audit: [
+            { name: 'SQLite DB', status: 'PASS', used: true, evidence: state.summary.total >= 0 ? 'DB opened successfully' : 'missing', risk: 'low' },
+            { name: 'Ledger', status: state.ledger.length > 0 ? 'PASS' : 'PARTIAL', used: true, evidence: `${state.ledger.length} ledger records`, risk: 'low' },
+            { name: 'Evidence', status: state.sourceCards.length > 0 ? 'PASS' : 'PARTIAL', used: true, evidence: `${state.sourceCards.length} source cards`, risk: 'medium' },
+            { name: 'Playwright', status: 'NOT_USED_WITH_REASON', used: false, evidence: 'not installed in current runtime', risk: 'medium' },
+            { name: 'Docker/Compose', status: 'PARTIAL', used: true, evidence: 'local compose artefact and smoke command available', risk: 'medium' },
+            {
+              name: 'GitHub read-only',
+              status: state.github.configured ? 'PARTIAL' : state.github.detectedOnly ? 'PARTIAL' : 'NOT_USED_WITH_REASON',
+              used: state.github.configured || state.github.detectedOnly,
+              evidence: state.github.reason,
+              risk: 'medium',
+            },
+            { name: 'GitHub write', status: 'BLOCKED', used: false, evidence: 'owner approval required', risk: 'high' },
+            { name: 'Slack', status: 'BLOCKED', used: false, evidence: 'owner approval required', risk: 'medium' },
+            { name: 'Browser/Chrome', status: 'PARTIAL', used: false, evidence: 'dashboard accessible locally', risk: 'medium' },
+          ],
+        }, null, 2));
+        return;
+      }
+
+      if (request.method === 'POST' && url.pathname === '/api/refresh') {
+        const body = await readRequestBody(request);
+        const payload = body ? JSON.parse(body) : {};
+        const state = await buildAppState(db, {
+          profile: payload.profile ?? 'dashboard',
+          query: payload.query ?? '',
+        });
+        response.writeHead(200, { 'content-type': 'application/json; charset=utf-8' });
+        response.end(JSON.stringify({ ok: true, state }, null, 2));
+        return;
+      }
+
+      response.writeHead(404, { 'content-type': 'application/json; charset=utf-8' });
+      response.end(JSON.stringify({ error: 'Not found' }));
+    } catch (error) {
+      response.writeHead(500, { 'content-type': 'application/json; charset=utf-8' });
+      response.end(JSON.stringify({ error: error instanceof Error ? error.message : String(error) }, null, 2));
+    }
+  });
+
+  server.listen(port, '127.0.0.1', () => {
+    const url = `http://127.0.0.1:${port}`;
+    console.log(`Pala OS V6 dashboard listening on ${url}`);
+    if (openBrowser) {
+      openUrl(url);
+    }
+  });
+
+  return server;
+}
