+    'evidence-watch',
+    'source-drift',
+    'secret-watch',
+    'docker-watch',
+    'mcp-watch',
+    'github-watch',
+    'token-watch',
+    'standard-watch',
+    'court-watch',
+  ];
+
+  watchers.forEach((watcher, index) => {
+    const finishedAt = new Date(startedAt.getTime() + 15 + (index * 5));
+    addJobRun(db, {
+      jobName: watcher,
+      status: state.summary.blocked > 0 && watcher === 'court-watch' ? 'attention' : 'ok',
+      detail: state.summary.blocked > 0
+        ? `blocked required standards: ${state.summary.blocked}`
+        : 'no blockers detected',
+      startedAt: startedAt.toISOString(),
+      finishedAt: finishedAt.toISOString(),
+      runtimeMs: finishedAt.getTime() - startedAt.getTime(),
+    });
+  });
+
+  addTokenSnapshot(db, {
+    taskName: 'cron-cycle',
+    plannedTokens: state.tokenBudget.plannedTokens,
+    actualTokens: state.tokenBudget.actualTokens,
+    notes: 'Cron cycle token estimate',
+  });
+
+  addToolUsage(db, {
+    toolName: 'cron',
+    purpose: 'Run local watcher jobs and record evidence',
+    context: { profile: 'cron', route: state.route },
+    tokensEstimated: state.tokenBudget.actualTokens,
+  });
+
+  addGateDecision(db, {
+    gateName: 'cron-cycle',
+    decision: state.summary.blocked > 0 ? 'blocked' : 'pass',
+    reason: state.summary.blocked > 0 ? 'required standards are still blocked' : 'no blocker in current snapshot',
+    context: { blocked: state.summary.blocked, route: state.route },
+  });
+
+  addEvent(db, {
+    kind: 'cron-cycle',
+    message: 'cron cycle completed',
+    payload: {
+      blocked: state.summary.blocked,
+      route: state.route,
+    },
+    source: 'cron',
+  });
