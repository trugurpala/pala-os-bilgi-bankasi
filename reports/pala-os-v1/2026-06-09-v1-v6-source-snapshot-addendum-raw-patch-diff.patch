+      source_ref: 'docs/world-standards-map.md',
+    },
+    {
+      name: 'source-court-review',
+      domain: 'infra',
+      status: 'draft',
+      path: 'docs/inheritance-backlog.json',
+      tier: 'core',
+      compatibility: ['codex', 'cursor', 'chatgpt'],
