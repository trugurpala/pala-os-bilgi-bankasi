+test('mcp stdio server serves read-only health and search tools', async (t) => {
+  const root = await createWorkspace();
+  t.after(async () => {
+    await rm(root, { recursive: true, force: true });
+  });
+
+  runCli(['bootstrap'], { PALA_ROOT_DIR: root });
+
+  const child = spawn(process.execPath, ['src/cli.js', 'mcp', 'serve'], {
+    cwd: repoRoot,
+    env: {
+      ...process.env,
+      PALA_ROOT_DIR: root,
+      PALA_OPEN_BROWSER: '0',
+    },
+    stdio: ['pipe', 'pipe', 'pipe'],
+  });
+
+  t.after(() => {
+    child.kill('SIGTERM');
+  });
+
+  let stdoutBuffer = '';
+  child.stdout.setEncoding('utf8');
+  child.stdout.on('data', (chunk) => {
+    stdoutBuffer += chunk;
+  });
+
+  let stderrBuffer = '';
+  child.stderr.setEncoding('utf8');
+  child.stderr.on('data', (chunk) => {
+    stderrBuffer += chunk;
+  });
+
+  const readResponse = async () => {
+    for (let attempt = 0; attempt < 40; attempt += 1) {
+      const lines = stdoutBuffer.split(/\r?\n/).filter(Boolean);
+      if (lines.length > 0) {
+        const line = lines.shift();
+        stdoutBuffer = `${lines.join('\n')}${lines.length ? '\n' : ''}`;
+        return JSON.parse(line);
+      }
+      await new Promise((resolve) => setTimeout(resolve, 50));
+    }
+    throw new Error(`timed out waiting for MCP response. stderr=${stderrBuffer}`);
+  };
+
+  for (let attempt = 0; attempt < 40; attempt += 1) {
+    if (stderrBuffer.includes('MCP read server ready')) {
+      break;
+    }
+    await new Promise((resolve) => setTimeout(resolve, 50));
+  }
+
+  child.stdin.write(`${JSON.stringify({ tool: 'pala_health', args: {} })}\n`);
+  const health = await readResponse();
+  assert.equal(health.ok, true);
+  assert.equal(health.release_state, 'RELEASE_BLOCKED');
+
+  child.stdin.write(`${JSON.stringify({ tool: 'pala_search_skills', args: { query: 'operator' } })}\n`);
+  const search = await readResponse();
+  assert.equal(search.ok, true);
+  assert.ok(search.skills.some((skill) => skill.name === 'pala-os-operator'));
+
+  child.stdin.write(`${JSON.stringify({ tool: 'shutdown', args: {} })}\n`);
+  const shutdown = await readResponse();
+  assert.equal(shutdown.status, 'shutting_down');
+  child.stdin.end();
+  await once(child, 'exit');
+});
