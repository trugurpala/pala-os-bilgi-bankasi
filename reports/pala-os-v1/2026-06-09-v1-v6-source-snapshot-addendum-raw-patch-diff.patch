+function escapeHtml(value) {
+  return String(value ?? '')
+    .replaceAll('&', '&amp;')
+    .replaceAll('<', '&lt;')
+    .replaceAll('>', '&gt;')
+    .replaceAll('"', '&quot;')
+    .replaceAll("'", '&#39;');
+}
+
+function pillClass(status) {
+  if (status === 'blocked' || status === 'bad' || status === 'attention') return 'bad';
+  if (status === 'required' || status === 'pass' || status === 'good' || status === 'ok') return 'good';
+  if (status === 'recommended' || status === 'neutral') return 'neutral';
+  return 'warn';
+}
+
+function familySlug(value) {
+  return String(value ?? '')
+    .toLowerCase()
+    .replaceAll(/[^a-z0-9]+/g, '-')
+    .replaceAll(/^-|-$/g, '');
+}
+
+function buildFamilyRows(standards) {
+  const summary = new Map();
+
+  for (const standard of standards) {
+    const family = standard.family;
+    if (!summary.has(family)) {
+      summary.set(family, {
+        family,
+        total: 0,
+        blocked: 0,
+        satisfied: 0,
+        recommended: 0,
+        notApplicable: 0,
+      });
+    }
+
+    const row = summary.get(family);
+    row.total += 1;
+    if (standard.status === 'blocked') row.blocked += 1;
+    if (standard.satisfied) row.satisfied += 1;
+    if (standard.status === 'recommended') row.recommended += 1;
+    if (standard.status === 'not_applicable_with_reason') row.notApplicable += 1;
+  }
+
+  return [...summary.values()].sort((left, right) => {
+    if (right.blocked !== left.blocked) {
+      return right.blocked - left.blocked;
+    }
+    return left.family.localeCompare(right.family);
+  });
+}
+
+function buildRoleCards(state) {
+  const blocked = state.summary.blocked ?? 0;
+  const sourceCount = state.sourceCards.length;
+  const jobAttention = state.jobRuns.filter((jobRun) => jobRun.status !== 'ok').length;
