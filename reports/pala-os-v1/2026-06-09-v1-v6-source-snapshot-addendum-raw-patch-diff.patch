@@ -0,0 +1,92 @@
+import readline from 'node:readline';
+import { bootstrapApp } from './bootstrap.js';
+import { palaGetSkill, palaHealth, palaListSkills, palaSearchSkills } from './mcp-read.js';
+
+const TOOL_ALLOWLIST = new Set([
+  'pala_health',
+  'pala_list_skills',
+  'pala_get_skill',
+  'pala_search_skills',
+]);
+
+async function dispatch(db, request) {
+  const tool = String(request?.tool ?? '').trim();
+  const args = request?.args ?? {};
+
+  if (!TOOL_ALLOWLIST.has(tool)) {
+    return {
+      ok: false,
+      error: `tool not allowed: ${tool || 'unknown'}`,
+      allowedTools: [...TOOL_ALLOWLIST],
+    };
+  }
+
+  switch (tool) {
+    case 'pala_health':
+      return palaHealth(db);
+    case 'pala_list_skills':
+      return palaListSkills(args);
+    case 'pala_get_skill':
+      return palaGetSkill(args.name);
+    case 'pala_search_skills':
+      return palaSearchSkills(args);
+    default:
+      return {
+        ok: false,
+        error: `tool not implemented: ${tool}`,
+      };
+  }
+}
+
+export async function startMcpServer({ input = process.stdin, output = process.stdout, error = process.stderr } = {}) {
+  const { db } = await bootstrapApp();
+
+  const rl = readline.createInterface({
+    input,
+    crlfDelay: Infinity,
+    terminal: false,
+  });
+
+  error.write('Pala OS V6 MCP read server ready\n');
+
+  rl.on('line', async (line) => {
+    const trimmed = line.trim();
+    if (!trimmed) {
+      return;
+    }
+
+    let request;
+    try {
+      request = JSON.parse(trimmed);
+    } catch (parseError) {
+      output.write(`${JSON.stringify({
+        ok: false,
+        error: 'invalid json request',
+      })}\n`);
+      return;
+    }
+
+    if (request?.tool === 'shutdown') {
+      output.write(`${JSON.stringify({
+        ok: true,
+        status: 'shutting_down',
+      })}\n`);
+      rl.close();
+      return;
+    }
+
+    try {
+      const payload = await dispatch(db, request);
+      output.write(`${JSON.stringify(payload)}\n`);
+    } catch (dispatchError) {
+      output.write(`${JSON.stringify({
+        ok: false,
+        error: dispatchError instanceof Error ? dispatchError.message : String(dispatchError),
+      })}\n`);
+    }
+  });
+
+  return new Promise((resolve) => {
+    rl.on('close', () => resolve());
+  });
+}
