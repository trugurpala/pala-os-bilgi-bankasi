index 0000000..f52e6a6
--- /dev/null
+++ b/source-snapshots/raw/pala-os-v6/src/screenshot.js
@@ -0,0 +1,89 @@
+import fs from 'node:fs/promises';
+import path from 'node:path';
+import { SCREENSHOTS_DIR } from './config.js';
+
+const PLACEHOLDER_PNG_BASE64 =
+  'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO7Z1y0AAAAASUVORK5CYII=';
+
+function slugify(value) {
+  return String(value ?? 'target')
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, '-')
+    .replace(/^-+|-+$/g, '')
+    .slice(0, 60) || 'target';
+}
+
+function isUnsafeTarget(targetUrl) {
+  if (!targetUrl) {
+    return true;
+  }
+
+  const lower = String(targetUrl).toLowerCase();
+  return lower.startsWith('file:') || lower.includes('.env') || lower.includes('secret') || lower.includes('token');
+}
+
+async function writePlaceholderPng(filePath) {
+  await fs.writeFile(filePath, Buffer.from(PLACEHOLDER_PNG_BASE64, 'base64'));
+}
+
+export async function captureScreenshotEvidence({
+  url,
+  selector = null,
+  fullPage = true,
+  label = 'screenshot',
+}) {
+  if (!url) {
+    throw new Error('screenshot requires --url');
+  }
+
+  if (isUnsafeTarget(url)) {
+    throw new Error('unsafe screenshot target blocked');
+  }
+
+  await fs.mkdir(SCREENSHOTS_DIR, { recursive: true });
+  const stamp = new Date().toISOString().replace(/[:.]/g, '-');
+  const baseName = `${stamp}-${slugify(label)}`;
+  const pngPath = path.join(SCREENSHOTS_DIR, `${baseName}.png`);
+  const metaPath = path.join(SCREENSHOTS_DIR, `${baseName}.json`);
+
+  let mode = 'placeholder';
+  let note = 'playwright not installed; placeholder screenshot written';
+
+  try {
+    const playwright = await import('playwright');
+    const browser = await playwright.chromium.launch({ headless: true });
+    const page = await browser.newPage();
+    await page.goto(url, { waitUntil: 'networkidle' });
+
+    if (selector) {
+      await page.locator(selector).screenshot({ path: pngPath });
+      note = `element screenshot captured for ${selector}`;
+    } else {
+      await page.screenshot({ path: pngPath, fullPage });
+      note = `page screenshot captured for ${url}`;
+    }
+
+    await browser.close();
+    mode = 'playwright';
+  } catch (error) {
+    await writePlaceholderPng(pngPath);
+    note = error instanceof Error && error.message.includes('Cannot find module')
+      ? 'playwright unavailable; placeholder screenshot written'
+      : `placeholder screenshot written (${error instanceof Error ? error.message : String(error)})`;
+  }
+
+  const metadata = {
