+  required('guac', 'GUAC', 'supply-chain', ['supply-chain', 'security'], ['standard-watch', 'court-watch']),
+  required('github-oidc-least-privilege', 'GitHub OIDC/least privilege', 'github', ['governance', 'security', 'github'], ['standard-watch', 'court-watch']),
+
+  required('mitre-attack', 'MITRE ATT&CK', 'threat-model', ['security', 'risk'], ['standard-watch', 'court-watch']),
+  required('mitre-cwe', 'MITRE CWE', 'threat-model', ['security', 'risk'], ['standard-watch', 'court-watch']),
+  required('mitre-capec', 'MITRE CAPEC', 'threat-model', ['security', 'risk'], ['standard-watch', 'court-watch']),
+  required('cve', 'CVE', 'metrics', ['security', 'risk'], ['standard-watch', 'court-watch']),
+  required('cvss', 'CVSS', 'metrics', ['security', 'risk'], ['standard-watch', 'court-watch']),
+  required('epss', 'EPSS', 'metrics', ['security', 'risk'], ['standard-watch', 'court-watch']),
+  required('cisa-kev', 'CISA KEV', 'metrics', ['security', 'risk'], ['standard-watch', 'court-watch']),
+  recommended('stride', 'STRIDE', 'risk', ['security', 'risk']),
+  recommended('dread', 'DREAD', 'risk', ['security', 'risk']),
+  recommended('pasta', 'PASTA', 'risk', ['security', 'risk']),
+
+  required('docker-least-privilege', 'Docker least privilege', 'runtime', ['runtime', 'security'], ['standard-watch', 'court-watch']),
+  required('kubernetes-pod-security-standards', 'Kubernetes Pod Security Standards', 'runtime', ['runtime', 'security'], ['standard-watch', 'court-watch']),
+  required('mcp-auth-tool-allowlist', 'MCP auth/tool allowlist', 'ai', ['ai', 'security'], ['standard-watch', 'court-watch']),
+  required('sbom-provenance', 'SBOM/provenance', 'supply-chain', ['supply-chain', 'security'], ['standard-watch', 'court-watch']),
+  required('pala-no-fake-done-ledger-law', 'Pala no-fake-done ledger law', 'philosophy', ['governance', 'philosophy'], ['standard-watch', 'court-watch']),
+];
+
+const CATALOG_GENERATED_AT = '2026-06-07T16:33:05.872Z';
+
+export const STANDARD_CATALOG = STANDARD_ROWS.map(([policyState, id, title, family, focus, watchers]) => ({
+  id,
+  title,
+  family,
+  policyState,
+  focus,
+  watchers,
+}));
+
+export const STANDARD_BY_ID = Object.fromEntries(
+  STANDARD_CATALOG.map((standard) => [standard.id, standard]),
+);
+
+export function catalogSeed() {
+  return {
+    version: 1,
+    generatedAt: CATALOG_GENERATED_AT,
+    standards: STANDARD_CATALOG,
+  };
+}
+
+export function searchStandards(query) {
+  const needle = String(query ?? '').trim().toLowerCase();
+  if (!needle) {
+    return STANDARD_CATALOG;
+  }
+
+  return STANDARD_CATALOG.filter((standard) => {
+    const haystack = [standard.id, standard.title, standard.family, ...standard.focus].join(' ').toLowerCase();
+    return haystack.includes(needle);
+  });
+}
