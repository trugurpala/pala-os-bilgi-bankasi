+        destructive_ops: false,
+      },
+      risk: 'low',
+      decision: 'IMPORT_LATER',
+      source_ref: 'src/context-pack.js',
+    },
+  ],
+};
+
+export async function ensureSeedSkillRegistry() {
+  try {
+    await fs.access(SEED_SKILLS_PATH);
+  } catch {
+    await fs.writeFile(SEED_SKILLS_PATH, `${JSON.stringify(SEED_SKILL_REGISTRY, null, 2)}\n`, 'utf8');
+  }
+}
+
+export async function loadSeedSkillRegistry() {
+  await ensureSeedSkillRegistry();
+  const content = await fs.readFile(SEED_SKILLS_PATH, 'utf8');
+  const parsed = JSON.parse(content);
+  return {
+    ...parsed,
+    skills: Array.isArray(parsed.skills) ? parsed.skills : [],
+  };
+}
+
+export function normalizeSkillRecord(skill) {
+  return {
+    ...skill,
+    compatibility: Array.isArray(skill.compatibility) ? skill.compatibility : [],
+    triggers: Array.isArray(skill.triggers) ? skill.triggers : [],
+  };
+}
+
+export function listRegistrySkills(registry, filters = {}) {
+  const query = String(filters.query ?? '').trim().toLowerCase();
+  const domain = String(filters.domain ?? '').trim().toLowerCase();
+  const status = String(filters.status ?? '').trim().toLowerCase();
+  const compatibility = String(filters.compatibility ?? '').trim().toLowerCase();
+
+  return registry.skills
+    .map(normalizeSkillRecord)
+    .filter((skill) => {
+      if (domain && skill.domain.toLowerCase() !== domain) {
+        return false;
+      }
+      if (status && skill.status.toLowerCase() !== status) {
+        return false;
+      }
+      if (compatibility && !skill.compatibility.some((item) => String(item).toLowerCase() === compatibility)) {
+        return false;
+      }
+      if (!query) {
+        return true;
+      }
+
+      const haystacks = [
+        skill.name,
+        skill.domain,
+        skill.path,
+        skill.tier,
+        skill.decision,
+        skill.source_ref,
+        ...(skill.triggers ?? []),
+      ].map((value) => String(value ?? '').toLowerCase());
+
+      return haystacks.some((value) => value.includes(query));
+    })
+    .sort((left, right) => left.name.localeCompare(right.name));
+}
+
+export function getRegistrySkill(registry, name) {
+  const target = String(name ?? '').trim().toLowerCase();
+  if (!target) {
+    return null;
+  }
+
+  return registry.skills
+    .map(normalizeSkillRecord)
+    .find((skill) => skill.name.toLowerCase() === target) ?? null;
+}
+
+export function buildRegistryHealth(registry) {
+  return {
+    ok: true,
+    status: registry.status ?? 'unknown',
+    total: Array.isArray(registry.skills) ? registry.skills.length : 0,
+    generatedFrom: Array.isArray(registry.generated_from) ? registry.generated_from : [],
+  };
+}
+
+export function summarizeSkillRegistry(registry) {
+  const summary = {
+    total: registry.skills.length,
+    byStatus: {},
+    byDomain: {},
+  };
+
+  for (const skill of registry.skills) {
+    summary.byStatus[skill.status] = (summary.byStatus[skill.status] ?? 0) + 1;
+    summary.byDomain[skill.domain] = (summary.byDomain[skill.domain] ?? 0) + 1;
+  }
+
+  return summary;
+}
