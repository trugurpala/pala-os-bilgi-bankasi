+      });
+      return {
+        message: 'docker smoke completed',
+        smoke,
+      };
+    });
+
+    console.log(JSON.stringify({ ok: result.smoke.ok, docker: result.smoke }, null, 2));
+    return;
+  }
+
+  printHelp();
+}
+
+main().catch((error) => {
+  console.error(error instanceof Error ? error.stack ?? error.message : String(error));
+  process.exitCode = 1;
+});
