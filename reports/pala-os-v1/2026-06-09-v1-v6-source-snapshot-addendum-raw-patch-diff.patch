+    selector,
+    fullPage,
+    pngPath,
+    metaPath,
+    mode,
+    note,
+    createdAt: new Date().toISOString(),
+  };
+
+  await fs.writeFile(metaPath, `${JSON.stringify(metadata, null, 2)}\n`, 'utf8');
