+def estimate_tokens(size_bytes: int) -> int:
+    return max(1, math.ceil(size_bytes / 4))
+
+
+def relative_path(path: Path) -> str:
+    try:
+        return str(path.relative_to(ROOT).as_posix())
+    except ValueError:
+        return str(path)
+
+
+def classify_token_file(path: Path, size_bytes: int) -> tuple[str, str]:
+    rel = relative_path(path)
+    rel_lower = rel.lower()
+    parts = [part.lower() for part in path.relative_to(ROOT).parts] if path.is_relative_to(ROOT) else [rel_lower]
+    name = path.name.lower()
+
+    if not name:
+        return DECISION_DO_NOT_READ, "Unclear filename"
+
+    if any(part in DO_NOT_READ_DIRS for part in parts):
+        return DECISION_DO_NOT_READ, "Blocked directory policy"
+
+    if "data/backups" in rel_lower:
+        return DECISION_DO_NOT_READ, "Backup data should remain out of session context"
+
+    if "data/reports" in rel_lower:
+        return DECISION_DO_NOT_READ, "Reports are retained for receipts, not for direct context read"
+
+    if name in {".env", ".env.local", ".env.production", ".env.test"}:
+        return DECISION_DO_NOT_READ, "Environment file"
+
+    if name in LOCK_FILES or path.suffix.lower() == ".lock":
+        return DECISION_DO_NOT_READ, "Dependency lock file"
+
+    if any(secret in rel_lower for secret in ("secret", "credential", "password", "apikey", "api_key", "token_api")):
+        return DECISION_DO_NOT_READ, "Potential secret-bearing filename"
+
+    if path.suffix.lower() in DO_NOT_READ_EXTENSIONS:
+        return DECISION_DO_NOT_READ, "Binary or non-text extension"
+
+    if rel in TOKEN_READ_FULL:
+        return DECISION_READ_FULL, "Core project and policy source"
+
+    if rel_lower.startswith("schema/") and path.suffix.lower() == ".json":
+        return DECISION_READ_FULL, "Schema file"
+
+    if rel_lower.startswith("docs/"):
+        if rel_lower == "docs/token-intelligence.md":
+            return DECISION_READ_FULL, "Token policy anchor document"
+        if size_bytes > LARGE_DOC_BYTES:
+            return DECISION_SUMMARY_ONLY, "Large docs file"
+        return DECISION_SUMMARY_ONLY, "Docs should be summarised before deep use"
+
+    if rel_lower == "dashboard/records.json":
+        return DECISION_SUMMARY_ONLY, "Large dashboard export cache"
+
+    if rel_lower.startswith("data/records/"):
+        return DECISION_SUMMARY_ONLY, "Record list should be indexed, not fully re-read"
+
+    if rel_lower.startswith("data/backups/"):
+        return DECISION_SUMMARY_ONLY, "Backup packages are history artifacts"
+
+    if rel_lower.startswith("data/inbox/"):
+        return DECISION_SUMMARY_ONLY, "Inbox content should be selectively reviewed"
+
+    if "node_modules/" in rel_lower:
+        return DECISION_DO_NOT_READ, "Dependency tree"
+
+    if "dist/" in rel_lower or "build/" in rel_lower or "coverage/" in rel_lower:
+        return DECISION_DO_NOT_READ, "Build artifact"
+
+    if size_bytes > READ_FULL_MAX_BYTES:
+        return DECISION_SUMMARY_ONLY, "Large file, summary source preferred"
+
+    if size_bytes > SUMMARY_ONLY_MAX_BYTES:
+        return DECISION_SUMMARY_ONLY, "Token-priority summary"
+
+    return DECISION_READ_FULL, "Small text/source file"
+
