+def build_token_intel() -> dict[str, Any]:
+    ensure_dirs()
+    decisions: list[dict[str, Any]] = []
+    scanned = 0
+    for current_root, dirnames, filenames in os.walk(ROOT):
+        current_path = Path(current_root)
+        rel_parts = []
+        try:
+            rel_parts = [part.lower() for part in current_path.relative_to(ROOT).parts]
+        except ValueError:
+            rel_parts = [part.lower() for part in current_path.parts]
+        dirnames[:] = [d for d in dirnames if d not in DO_NOT_READ_DIRS and d != ".pala"]
+
+        for fname in filenames:
+            path = current_path / fname
+            if scanned >= MAX_TOKEN_FILES_SCAN:
+                break
+            if path.name == ".gitkeep":
+                continue
+            rel = relative_path(path)
+            if rel == ".pala/config.json":
+                continue
+            if rel == "pala.config.json":
+                continue
+            if rel == "data/records":
+                continue
+            try:
+                size = path.stat().st_size
+            except (OSError, FileNotFoundError):
+                continue
+            if not path.is_file():
+                continue
+            decision, reason = classify_token_file(path, size)
+            decisions.append(
+                {
+                    "path": rel,
+                    "size_bytes": size,
+                    "decision": decision,
+                    "reason": reason,
+                }
+            )
+            scanned += 1
+
+    read_full = [d for d in decisions if d["decision"] == DECISION_READ_FULL]
+    summary_only = [d for d in decisions if d["decision"] == DECISION_SUMMARY_ONLY]
+    do_not_read = [d for d in decisions if d["decision"] == DECISION_DO_NOT_READ]
+    largest_files = sorted(decisions, key=lambda d: d["size_bytes"], reverse=True)[:10]
+    top_summary = sorted(summary_only, key=lambda d: d["size_bytes"])[:5]
+    do_not_read_list = [item["path"] for item in sorted(do_not_read, key=lambda d: d["size_bytes"], reverse=True)[:12]]
+
+    read_full_tokens = sum(estimate_tokens(item["size_bytes"]) for item in read_full)
+    summary_tokens = sum(estimate_tokens(item["size_bytes"]) for item in summary_only)
+    predicted_tokens = read_full_tokens + math.ceil(summary_tokens * 0.25)
+    token_ratio = min(1.0, predicted_tokens / TOKEN_BUDGET_WINDOW) if TOKEN_BUDGET_WINDOW else 0.0
+    compaction_needed = token_ratio >= 0.7
+    if token_ratio >= 0.85:
+        risk = "HIGH"
+    elif token_ratio >= 0.5:
+        risk = "MEDIUM"
+    else:
+        risk = "LOW"
+
+    dashboard_cards: dict[str, Any] = {
+        "token_budget": {
+            "safe_estimate": TOKEN_BUDGET_WINDOW,
+            "predicted_tokens": predicted_tokens,
+            "context_ratio": round(token_ratio, 3),
+        },
+        "context_risk": risk,
+        "files_read": len(read_full) + len(summary_only),
+        "files_blocked": len(do_not_read),
+        "largest_token_sources": [
+            {
+                "path": item["path"],
+                "size_bytes": item["size_bytes"],
+                "estimated_tokens": estimate_tokens(item["size_bytes"]),
+            }
+            for item in largest_files[:10]
+        ],
+        "recommended_next_read": [
+            {
+                "path": item["path"],
+                "estimated_tokens": estimate_tokens(item["size_bytes"]),
+            }
+            for item in top_summary[:5]
+        ],
+        "do_not_read": do_not_read_list,
+        "prompt_cache_candidate": "README.md",
+        "compaction_needed": compaction_needed,
+    }
+
+    summary: dict[str, Any] = {
+        "files_scanned": len(decisions),
+        "read_full": len(read_full),
+        "summary_only": len(summary_only),
+        "do_not_read": len(do_not_read),
+        "largest_files": [
+            {
+                "path": item["path"],
+                "size_bytes": item["size_bytes"],
+                "estimated_tokens": estimate_tokens(item["size_bytes"]),
+                "decision": item["decision"],
+            }
+            for item in largest_files
+        ],
+    }
+
+    return {
+        "generated_at": now_utc().isoformat(),
+        "repo_root": str(ROOT),
+        "summary": summary,
+        "decisions": decisions,
+        "dashboard_cards": dashboard_cards,
+    }
+
+
