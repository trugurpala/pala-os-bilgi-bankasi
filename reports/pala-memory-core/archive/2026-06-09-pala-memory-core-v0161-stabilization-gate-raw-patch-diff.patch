+    function renderPathList(elementId, entries) {
+      const element = document.getElementById(elementId);
+      if (!element) return;
+      if (!Array.isArray(entries) || entries.length === 0) {
+        element.textContent = "—";
+        return;
+      }
+      element.textContent = "";
+      const lines = [];
+      for (const item of entries.slice(0, 4)) {
+        const path = String(item.path || item).slice(0, 72);
+        const estimate = item.estimated_tokens ? ` (~${item.estimated_tokens} tok)` : "";
+        lines.push(`${path}${estimate}`);
+      }
+      element.innerHTML = lines.map((line) => `<div>${line}</div>`).join("");
+    }
