+def record_project_names(record: dict[str, Any]) -> list[str]:
+    return [project.get("name", "") for project in record.get("project_refs", []) if project.get("name")]
+
+
+def record_task_texts(record: dict[str, Any]) -> list[str]:
+    return [str(task.get("text", "")) for task in record.get("tasks", [])]
+
+
+def record_metadata_text(record: dict[str, Any]) -> str:
+    parts = [
+        str(record.get("id", "")),
+        str(record.get("title", "")),
+        str(record.get("summary", "")),
+        str(record.get("source", "")),
+        " ".join(str(tag) for tag in record.get("tags", [])),
+        " ".join(record_project_names(record)),
+        " ".join(str(item) for item in record.get("decisions", [])),
+        " ".join(record_task_texts(record)),
+        " ".join(str(item.get("value", "")) for item in record.get("evidence", [])),
+    ]
+    return "\n".join(parts)
+
+
+def read_record_text(record: dict[str, Any], max_chars: int = 20000) -> str:
+    raw_path = record.get("raw_text_path")
+    if not raw_path:
+        return ""
+    path = (ROOT / str(raw_path)).resolve()
+    try:
+        if ROOT not in path.parents and path != ROOT:
+            return ""
+        return path.read_text(encoding="utf-8", errors="replace")[:max_chars]
+    except OSError:
+        return ""
+
+
+def record_search_text(record: dict[str, Any], include_raw: bool = True) -> str:
+    text = record_metadata_text(record)
+    if include_raw:
+        text = f"{text}\n{read_record_text(record)}"
+    return text
+
+
+def record_matches_filters(record: dict[str, Any], args: argparse.Namespace) -> bool:
+    if getattr(args, "source", None) and record.get("source") != args.source:
+        return False
+    if getattr(args, "tag", None):
+        tags = {str(tag) for tag in record.get("tags", [])}
+        if not set(args.tag).issubset(tags):
+            return False
+    if getattr(args, "project", None):
+        projects = record_project_names(record)
+        if args.project not in projects:
+            return False
+    return True
+
+
+def records_for_args(args: argparse.Namespace) -> list[dict[str, Any]]:
+    date = getattr(args, "date", None)
+    if getattr(args, "all", False):
+        date = None
+    return [record for record in load_records(date) if record_matches_filters(record, args)]
+
+
+def record_line(record: dict[str, Any]) -> str:
+    created = str(record.get("created_at", ""))[:19].replace("T", " ")
+    source = record.get("source", "memory")
+    title = record.get("title", "Untitled memory")
+    return f"{record.get('id')} | {created} | {source} | {title}"
+
+
+def print_record_summary(record: dict[str, Any], include_paths: bool = True) -> None:
+    print(record_line(record))
+    summary = str(record.get("summary", "")).strip()
+    if summary:
+        print(f"  summary: {summary}")
+    if include_paths:
+        print(f"  record: {record.get('raw_text_path', '')}")
+        attachments = record.get("attachments", [])
+        if attachments:
+            print(f"  attachments: {len(attachments)}")
+
+
+def list_records(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    records = sorted(records_for_args(args), key=lambda item: item.get("created_at", ""), reverse=True)
+    if getattr(args, "json", False):
+        print(json.dumps(records[: args.limit], indent=2, ensure_ascii=True))
+        return
+    scope = "all records" if args.all or not args.date else f"date={args.date}"
+    print(f"records found={len(records)} scope={scope}")
+    for record in records[: args.limit]:
+        print_record_summary(record)
+
+
+def find_record(identifier: str) -> dict[str, Any]:
+    records = load_records()
+    matches = [
+        record
+        for record in records
+        if str(record.get("id", "")).startswith(identifier)
+        or Path(str(record.get("raw_text_path", ""))).stem.startswith(identifier)
+    ]
+    if not matches:
+        raise SystemExit(f"record not found: {identifier}")
+    if len(matches) > 1:
+        options = ", ".join(str(record.get("id")) for record in matches[:8])
+        raise SystemExit(f"record id is ambiguous: {identifier}; matches: {options}")
+    return matches[0]
+
+
+def show_record(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    record = find_record(args.identifier)
+    if args.json:
+        print(json.dumps(record, indent=2, ensure_ascii=True))
+        return
+    print_record_summary(record)
+    print(f"  json: {record.get('_json_path', '')}")
+    projects = record_project_names(record)
+    if projects:
+        print(f"  projects: {', '.join(projects)}")
+    tags = record.get("tags", [])
+    if tags:
+        print(f"  tags: {', '.join(str(tag) for tag in tags)}")
+    tasks = record_task_texts(record)
+    if tasks:
+        print("  tasks:")
+        for task in tasks:
+            print(f"    - {task}")
+    evidence = record.get("evidence", [])
+    if evidence:
+        print("  evidence:")
+        for item in evidence:
+            print(f"    - {item.get('kind')}: {item.get('value')}")
+    if args.raw:
+        print("")
+        print(read_record_text(record, max_chars=args.max_chars))
+
