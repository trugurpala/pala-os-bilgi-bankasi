+def command_available(name: str) -> bool:
+    return shutil.which(name) is not None
+
+
+def run_probe(command: list[str], cwd: Path | None = None, timeout: int = 8) -> subprocess.CompletedProcess[str] | None:
+    try:
+        return subprocess.run(command, cwd=cwd, capture_output=True, text=True, timeout=timeout, check=False)
+    except (OSError, subprocess.SubprocessError):
+        return None
+
+
+def add_check(checks: list[dict[str, Any]], name: str, status: str, detail: str, system: str) -> None:
+    checks.append({"name": name, "status": status, "detail": detail, "system": system})
+
+
+def path_exists_in_root(value: str) -> bool:
+    if not value:
+        return False
+    path = (ROOT / value).resolve()
+    return (path == ROOT or ROOT in path.parents) and path.exists()
+
+
+def doctor_report(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    records = load_records()
+    checks: list[dict[str, Any]] = []
+
+    add_check(
+        checks,
+        "Python runtime",
+        "PASS" if sys.version_info >= (3, 10) else "FAIL",
+        f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}",
+        "runtime",
+    )
+
+    required_dirs = [DATA, RECORDS, REPORTS, ATTACHMENTS, BACKUPS, DATA / "inbox"]
+    missing_dirs = [str(path.relative_to(ROOT)) for path in required_dirs if not path.exists()]
+    add_check(
+        checks,
+        "Local data folders",
+        "PASS" if not missing_dirs else "FAIL",
+        "ready" if not missing_dirs else f"missing: {', '.join(missing_dirs)}",
+        "local-storage",
+    )
+
+    add_check(
+        checks,
+        "Record vault",
+        "PASS" if records else "WARN",
+        f"records={len(records)}",
+        "memory-records",
+    )
+
+    missing_raw = [record.get("id", "unknown") for record in records if not path_exists_in_root(str(record.get("raw_text_path", "")))]
+    add_check(
+        checks,
+        "Markdown record links",
+        "PASS" if not missing_raw else "FAIL",
+        "all raw_text_path files exist" if not missing_raw else f"missing={len(missing_raw)}",
+        "memory-records",
+    )
+
+    attachments = [
+        attachment
+        for record in records
+        for attachment in record.get("attachments", [])
+    ]
+    missing_attachments = [
+        attachment.get("path", "")
+        for attachment in attachments
+        if not path_exists_in_root(str(attachment.get("path", "")))
+    ]
+    add_check(
+        checks,
+        "Attachment files",
+        "PASS" if not missing_attachments else "FAIL",
+        f"attachments={len(attachments)} missing={len(missing_attachments)}",
+        "files",
+    )
+
+    add_check(
+        checks,
+        "Secret redaction rules",
+        "PASS" if SECRET_PATTERNS else "FAIL",
+        f"patterns={len(SECRET_PATTERNS)}",
+        "backup-safety",
+    )
+
+    dashboard_index = DASHBOARD / "index.html"
+    dashboard_data = DASHBOARD / "records.json"
+    add_check(
+        checks,
+        "Dashboard shell",
+        "PASS" if dashboard_index.exists() else "FAIL",
+        str(dashboard_index.relative_to(ROOT)) if dashboard_index.exists() else "missing dashboard/index.html",
+        "dashboard",
+    )
+    add_check(
+        checks,
+        "Dashboard export data",
+        "PASS" if dashboard_data.exists() else "WARN",
+        str(dashboard_data.relative_to(ROOT)) if dashboard_data.exists() else "run: python pala.py dashboard export --all",
+        "dashboard",
+    )
+
+    add_check(checks, "Recovery CLI", "PASS", "list/search/show commands are registered", "recovery")
+    add_check(checks, "ChatGPT export importer", "PASS", "zip/folder/json/html/md/txt import path is registered", "chatgpt")
+    add_check(checks, "Mobile share importer", "PASS", "file/folder/zip import path is registered", "mobile")
+    add_check(checks, "Mobile share watcher", "PASS", "watch mobile-share command is registered", "mobile")
+    add_check(checks, "Browser URL capture", "PASS", "stdlib urllib capture path is registered", "browser")
+
+    playwright_ready = importlib.util.find_spec("playwright") is not None
+    add_check(
+        checks,
+        "Playwright capture",
+        "PASS" if playwright_ready else "WARN",
+        "playwright package installed" if playwright_ready else "optional dependency missing; install with python -m pip install playwright",
+        "browser",
+    )
+
+    git_ready = command_available("git")
+    add_check(
+        checks,
+        "Git command",
+        "PASS" if git_ready else "WARN",
+        "git available" if git_ready else "git command not found",
+        "github",
+    )
+
+    gh_ready = command_available("gh")
+    gh_status = run_probe(["gh", "auth", "status"]) if gh_ready else None
+    gh_ok = bool(gh_status and gh_status.returncode == 0)
+    add_check(
+        checks,
+        "GitHub CLI auth",
+        "PASS" if gh_ok else "WARN",
+        "gh auth status ok" if gh_ok else "gh not authenticated or unavailable",
+        "github",
+    )
+
+    kb_root = knowledge_bank_path(args.knowledge_bank)
+    kb_git = kb_root / ".git"
+    add_check(
+        checks,
+        "Knowledge-bank repo",
+        "PASS" if kb_git.exists() else "WARN",
+        str(kb_root) if kb_git.exists() else f"not a git repo or missing: {kb_root}",
+        "knowledge-bank",
+    )
+
+    drive_root = drive_backup_path(args.drive_target)
+    add_check(
+        checks,
+        "Drive folder target",
+        "PASS" if drive_root.exists() else "WARN",
+        str(drive_root) if drive_root.exists() else f"not created yet: {drive_root}",
+        "drive",
+    )
+
+    status_counts = {
+        "PASS": sum(1 for check in checks if check["status"] == "PASS"),
+        "WARN": sum(1 for check in checks if check["status"] == "WARN"),
+        "FAIL": sum(1 for check in checks if check["status"] == "FAIL"),
+    }
+    active_systems = len({check["system"] for check in checks if check["status"] == "PASS"})
+    payload = {
+        "generated_at": now_utc().isoformat(),
+        "active_systems": active_systems,
+        "status_counts": status_counts,
+        "checks": checks,
+    }
+
+    if args.json:
+        print(json.dumps(payload, indent=2, ensure_ascii=True))
+    else:
+        print("Pala Memory Core Doctor")
+        print(f"active_systems={active_systems} pass={status_counts['PASS']} warn={status_counts['WARN']} fail={status_counts['FAIL']}")
+        for check in checks:
+            print(f"{check['status']:4} | {check['system']:16} | {check['name']} | {check['detail']}")
+
+    if args.strict and status_counts["FAIL"]:
+        raise SystemExit(1)
+
+
