+        const stats = data.stats || {};
+        setText("stat-records", stats.records);
+        setText("stat-projects", stats.projects);
+        setText("stat-files", stats.files);
+        setText("stat-tasks", stats.open_tasks);
+        renderTimeline(data.records || []);
+      } catch (_error) {
+        // The static demo remains visible when no exported data exists.
+      }
+    }
+
+    function setText(id, value) {
+      if (value === undefined || value === null) return;
+      const element = document.getElementById(id);
+      if (element) element.textContent = String(value);
+    }
+
+    function renderTimeline(records) {
+      const timeline = document.getElementById("timeline");
+      if (!timeline || records.length === 0) return;
+      timeline.replaceChildren();
+      for (const record of records.slice().reverse()) {
+        const article = document.createElement("article");
+        article.className = "record";
+
+        const time = document.createElement("div");
+        time.className = "time";
+        time.textContent = formatTime(record.created_at);
+
+        const body = document.createElement("div");
+        const title = document.createElement("h3");
+        title.textContent = record.title || "Untitled memory";
+        const summary = document.createElement("p");
+        summary.textContent = record.summary || "";
+        body.append(title, summary);
+
+        const chip = document.createElement("span");
+        chip.className = "chip";
+        chip.textContent = record.source || "memory";
+
+        article.append(time, body, chip);
+        timeline.append(article);
+      }
+    }
