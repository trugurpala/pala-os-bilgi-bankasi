@@ -0,0 +1,342 @@
+#!/usr/bin/env python3
+"""Pala Memory Core MVP CLI.
+
+This is a zero-dependency starter CLI for local-first memory capture.
+It writes human-readable Markdown records plus JSON metadata.
+"""
+
+from __future__ import annotations
+
+import argparse
+import datetime as dt
+import hashlib
+import http.server
+import json
+import shutil
+import socketserver
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+DATA = ROOT / "data"
+RECORDS = DATA / "records"
+REPORTS = DATA / "reports"
+ATTACHMENTS = DATA / "attachments"
+BACKUPS = DATA / "backups"
+DASHBOARD = ROOT / "dashboard"
+
+
+def ensure_dirs() -> None:
+    for path in [DATA, RECORDS, REPORTS, ATTACHMENTS, BACKUPS, DATA / "inbox"]:
+        path.mkdir(parents=True, exist_ok=True)
+
+
+def now_utc() -> dt.datetime:
+    return dt.datetime.now(dt.timezone.utc)
+
+
+def stamp() -> str:
+    return now_utc().strftime("%Y%m%dT%H%M%SZ")
+
+
+def today() -> str:
+    return dt.datetime.now().strftime("%Y-%m-%d")
+
+
+def slug(value: str) -> str:
+    clean = []
+    for char in value.lower():
+        if char.isalnum():
+            clean.append(char)
+        elif char in [" ", "-", "_"]:
+            clean.append("-")
+    collapsed = "-".join(part for part in "".join(clean).split("-") if part)
+    return collapsed[:60] or "memory"
+
+
+def sha256(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def copy_attachment(path: Path, record_id: str) -> dict[str, str]:
+    target_dir = ATTACHMENTS / record_id
+    target_dir.mkdir(parents=True, exist_ok=True)
+    target = target_dir / path.name
+    shutil.copy2(path, target)
+    suffix = path.suffix.lower().lstrip(".")
+    kind = {
+        "pdf": "pdf",
+        "png": "image",
+        "jpg": "image",
+        "jpeg": "image",
+        "md": "markdown",
+        "txt": "text",
+        "patch": "patch",
+        "zip": "archive",
+    }.get(suffix, "other")
+    return {
+        "path": str(target.relative_to(ROOT)),
+        "kind": kind,
+        "sha256": sha256(target),
+    }
+
+
+def write_record(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    record_id = f"{stamp()}-{slug(args.title)}"
+    record_dir = RECORDS / today()
+    record_dir.mkdir(parents=True, exist_ok=True)
+
+    text = args.text or ""
+    if args.text_file:
+        text_file = Path(args.text_file).expanduser().resolve()
+        text = text_file.read_text(encoding="utf-8")
+
+    attachments = []
+    for item in args.file or []:
+        path = Path(item).expanduser().resolve()
+        attachments.append(copy_attachment(path, record_id))
+
+    summary = args.summary or (text.strip().replace("\n", " ")[:280] if text.strip() else args.title)
+    created_at = now_utc().isoformat()
+    md_path = record_dir / f"{record_id}.md"
+    json_path = record_dir / f"{record_id}.json"
+
+    markdown = f"""# {args.title}
+
+Created: {created_at}
+Source: {args.source}
+Project: {args.project or "unlinked"}
+
+## Summary
+
+{summary}
+
+## Raw Text
+
+```text
+{text.strip()}
+```
+
+## Attachments
+
+{format_list([item["path"] for item in attachments])}
+
+## Decisions
+
+{format_list(args.decision or [])}
+
+## Tasks
+
+{format_list(args.task or [])}
+"""
+    md_path.write_text(markdown, encoding="utf-8")
+
+    record: dict[str, Any] = {
+        "id": record_id,
+        "created_at": created_at,
+        "source": args.source,
+        "title": args.title,
+        "summary": summary,
+        "raw_text_path": str(md_path.relative_to(ROOT)),
+        "attachments": attachments,
+        "project_refs": project_refs(args.project),
+        "tags": args.tag or [],
+        "decisions": args.decision or [],
+        "tasks": [{"text": item, "status": "open"} for item in (args.task or [])],
+        "evidence": [],
+        "backup_status": {
+            "local": "complete",
+            "github": "pending",
+            "google_drive": "pending",
+            "last_backup_at": created_at,
+            "receipt": "",
+        },
+    }
+    json_path.write_text(json.dumps(record, indent=2, ensure_ascii=True), encoding="utf-8")
+    print(f"saved {record_id}")
+    print(str(md_path.relative_to(ROOT)))
+
+
+def project_refs(project: str | None) -> list[dict[str, str]]:
+    if not project:
+        return []
+    kind = "github_repo" if "/" in project and not project.startswith((".", "/", "\\")) else "local_folder"
+    return [{"name": project, "kind": kind}]
+
+
+def format_list(items: list[str]) -> str:
+    if not items:
+        return "- none"
+    return "\n".join(f"- {item}" for item in items)
+
+
+def load_today_records() -> list[dict[str, Any]]:
+    record_dir = RECORDS / today()
+    if not record_dir.exists():
+        return []
+    records = []
+    for path in sorted(record_dir.glob("*.json")):
+        records.append(json.loads(path.read_text(encoding="utf-8")))
+    return records
+
+
+def brief_today(_args: argparse.Namespace) -> None:
+    ensure_dirs()
+    records = load_today_records()
+    report_path = REPORTS / f"{today()}-brief.md"
+    lines = [
+        f"# Daily Brief - {today()}",
+        "",
+        f"Records: {len(records)}",
+        "",
+        "## Timeline",
+        "",
+    ]
+    for record in records:
+        lines.extend(
+            [
+                f"### {record['title']}",
+                "",
+                f"- Source: {record['source']}",
+                f"- Summary: {record['summary']}",
+                f"- Record: {record['raw_text_path']}",
+                "",
+            ]
+        )
+    lines.extend(["## Open Tasks", ""])
+    open_tasks = [
+        task["text"]
+        for record in records
+        for task in record.get("tasks", [])
+        if task.get("status") != "done"
+    ]
+    lines.append(format_list(open_tasks))
+    report_path.write_text("\n".join(lines), encoding="utf-8")
+    print(f"brief saved {report_path.relative_to(ROOT)}")
+
+
+def backup_receipt(_args: argparse.Namespace) -> None:
+    ensure_dirs()
+    records = load_today_records()
+    receipt_path = BACKUPS / f"{today()}-backup-receipt.md"
+    lines = [
+        f"# Backup Receipt - {today()}",
+        "",
+        f"Created: {now_utc().isoformat()}",
+        f"Records included: {len(records)}",
+        "",
+        "## Status",
+        "",
+        "- Local: complete",
+        "- GitHub: pending",
+        "- Google Drive: pending",
+        "",
+        "## Records",
+        "",
+    ]
+    lines.append(format_list([record["raw_text_path"] for record in records]))
+    receipt_path.write_text("\n".join(lines), encoding="utf-8")
+    print(f"receipt saved {receipt_path.relative_to(ROOT)}")
+
+
+def dashboard_export(_args: argparse.Namespace) -> None:
+    ensure_dirs()
+    DASHBOARD.mkdir(parents=True, exist_ok=True)
+    records = load_today_records()
+    open_tasks = [
+        task
+        for record in records
+        for task in record.get("tasks", [])
+        if task.get("status") != "done"
+    ]
+    linked_projects = {
+        project.get("name")
+        for record in records
+        for project in record.get("project_refs", [])
+        if project.get("name")
+    }
+    attachment_count = sum(len(record.get("attachments", [])) for record in records)
+    payload = {
+        "generated_at": now_utc().isoformat(),
+        "date": today(),
+        "stats": {
+            "records": len(records),
+            "projects": len(linked_projects),
+            "files": attachment_count,
+            "open_tasks": len(open_tasks),
+        },
+        "records": records,
+    }
+    target = DASHBOARD / "records.json"
+    target.write_text(json.dumps(payload, indent=2, ensure_ascii=True), encoding="utf-8")
+    print(f"dashboard data saved {target.relative_to(ROOT)}")
+
+
+def dashboard_serve(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    DASHBOARD.mkdir(parents=True, exist_ok=True)
+    handler = lambda *handler_args, **handler_kwargs: http.server.SimpleHTTPRequestHandler(
+        *handler_args,
+        directory=str(DASHBOARD),
+        **handler_kwargs,
+    )
+    with socketserver.TCPServer((args.host, args.port), handler) as server:
+        url = f"http://{args.host}:{args.port}"
+        print(f"serving dashboard at {url}")
+        print("press Ctrl+C to stop")
+        server.serve_forever()
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(prog="pala", description="Pala Memory Core MVP CLI")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    remember = sub.add_parser("remember", help="save a memory record")
+    remember.add_argument("--title", required=True)
+    remember.add_argument("--text", default="")
+    remember.add_argument("--text-file")
+    remember.add_argument("--summary")
+    remember.add_argument("--source", default="manual")
+    remember.add_argument("--project")
+    remember.add_argument("--tag", action="append")
+    remember.add_argument("--decision", action="append")
+    remember.add_argument("--task", action="append")
+    remember.add_argument("--file", action="append")
+    remember.set_defaults(func=write_record)
+
+    brief = sub.add_parser("brief", help="create a brief")
+    brief_sub = brief.add_subparsers(dest="period", required=True)
+    today_cmd = brief_sub.add_parser("today", help="brief today's records")
+    today_cmd.set_defaults(func=brief_today)
+
+    backup = sub.add_parser("backup", help="create backup artifacts")
+    backup_sub = backup.add_subparsers(dest="target", required=True)
+    receipt = backup_sub.add_parser("receipt", help="create a local backup receipt")
+    receipt.set_defaults(func=backup_receipt)
+
+    dashboard = sub.add_parser("dashboard", help="dashboard utilities")
+    dashboard_sub = dashboard.add_subparsers(dest="action", required=True)
+    export = dashboard_sub.add_parser("export", help="export dashboard data")
+    export.set_defaults(func=dashboard_export)
+    serve = dashboard_sub.add_parser("serve", help="serve local dashboard")
+    serve.add_argument("--host", default="127.0.0.1")
+    serve.add_argument("--port", type=int, default=8765)
+    serve.set_defaults(func=dashboard_serve)
+
+    return parser
+
+
+def main() -> None:
+    parser = build_parser()
+    args = parser.parse_args()
+    args.func(args)
+
+
+if __name__ == "__main__":
+    main()
