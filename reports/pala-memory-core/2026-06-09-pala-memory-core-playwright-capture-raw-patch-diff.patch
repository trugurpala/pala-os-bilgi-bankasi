@@ -713,6 +713,56 @@ def capture_browser(args: argparse.Namespace) -> None:
     print(f"captured browser url {args.url}")
 
 
+def capture_playwright(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    try:
+        from playwright.sync_api import sync_playwright
+    except ImportError as error:
+        raise SystemExit(
+            "Playwright is not installed. Install with: "
+            "python -m pip install playwright && python -m playwright install chromium"
+        ) from error
+
+    screenshot_paths: list[str] = []
+    with sync_playwright() as playwright:
+        browser_launcher = getattr(playwright, args.browser)
+        browser = browser_launcher.launch(headless=not args.headed)
+        context_kwargs: dict[str, Any] = {}
+        if args.storage_state:
+            context_kwargs["storage_state"] = args.storage_state
+        context = browser.new_context(**context_kwargs)
+        page = context.new_page()
+        page.goto(args.url, wait_until=args.wait_until, timeout=args.timeout * 1000)
+        if args.wait_ms:
+            page.wait_for_timeout(args.wait_ms)
+        text = page.inner_text("body")
+        if args.screenshot:
+            screenshot_dir = DATA / "inbox" / "playwright-captures"
+            screenshot_dir.mkdir(parents=True, exist_ok=True)
+            screenshot_path = unique_path(screenshot_dir / f"{stamp()}-{slug(args.title or args.url)}.png")
+            page.screenshot(path=str(screenshot_path), full_page=args.full_page)
+            screenshot_paths.append(str(screenshot_path))
+        context.close()
+        browser.close()
+
+    write_record(
+        argparse.Namespace(
+            title=args.title or f"Playwright capture: {args.url}",
+            text=text[: args.max_chars],
+            text_file=None,
+            summary=args.summary,
+            source="playwright",
+            project=args.project,
+            tag=["playwright-capture", *(args.tag or [])],
+            decision=[],
+            task=[],
+            file=screenshot_paths,
+            evidence=[{"kind": "url", "value": args.url}],
+        )
+    )
+    print(f"captured playwright url {args.url} screenshots={len(screenshot_paths)}")
+
+
 def collect_import_entries(source: Path, max_chars: int) -> list[tuple[str, str]]:
     if source.is_dir():
         entries: list[tuple[str, str]] = []
