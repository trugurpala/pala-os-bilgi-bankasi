+def backup_drive(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    records = load_today_records()
+    drive_root = drive_backup_path(args.target)
+    drive_root.mkdir(parents=True, exist_ok=True)
+
+    package_id = f"{today()}-{stamp()}-pala-memory-core-drive-backup"
+    target = drive_root / package_id
+    target.mkdir(parents=True, exist_ok=False)
+
+    manifest_records = []
+    for record in records:
+        manifest_records.append(
+            {
+                "id": record.get("id"),
+                "created_at": record.get("created_at"),
+                "source": record.get("source"),
+                "title": redact_text(str(record.get("title", ""))),
+                "summary": redact_text(str(record.get("summary", ""))),
+                "project_refs": record.get("project_refs", []),
+                "tags": [redact_text(str(tag)) for tag in record.get("tags", [])],
+                "tasks": [
+                    {"text": redact_text(str(task.get("text", ""))), "status": task.get("status", "open")}
+                    for task in record.get("tasks", [])
+                ],
+                "attachments": record.get("attachments", []),
+            }
+        )
+
+    report_lines = [
+        f"# Pala Memory Core Drive Backup - {today()}",
+        "",
+        f"Created: {now_utc().isoformat()}",
+        f"Source repo: {ROOT}",
+        f"Records included: {len(records)}",
+        "",
+        "## Records",
+        "",
+    ]
+    for record in manifest_records:
+        report_lines.extend(
+            [
+                f"### {record['title'] or record['id']}",
+                "",
+                f"- ID: {record['id']}",
+                f"- Source: {record['source']}",
+                f"- Summary: {record['summary']}",
+                f"- Projects: {', '.join(project.get('name', '') for project in record['project_refs']) or 'none'}",
+                "",
+            ]
+        )
+    report_lines.extend(
+        [
+            "## Backup Policy",
+            "",
+            "- Raw conversation text is not copied by default.",
+            "- Common token/API key/private key patterns are redacted.",
+            "- Point --target at a Google Drive sync folder for cloud sync.",
+        ]
+    )
+
+    write_redacted_text(target / "drive-backup-report.md", "\n".join(report_lines))
+    write_redacted_text(target / "records-manifest.json", json.dumps(manifest_records, indent=2, ensure_ascii=True))
+
+    optional_artifacts = [
+        REPORTS / f"{today()}-brief.md",
+        BACKUPS / f"{today()}-backup-receipt.md",
+        DASHBOARD / "records.json",
+    ]
+    artifact_dir = target / "artifacts"
+    copied = []
+    for artifact in optional_artifacts:
+        if artifact.exists():
+            destination = artifact_dir / artifact.name
+            write_redacted_text(destination, artifact.read_text(encoding="utf-8"))
+            copied.append(str(destination.relative_to(target)))
+
+    receipt = {
+        "created_at": now_utc().isoformat(),
+        "package": str(target),
+        "records": len(records),
+        "artifacts": copied,
+        "target": str(drive_root),
+        "sync_mode": "folder",
+    }
+    write_redacted_text(target / "drive-backup-receipt.json", json.dumps(receipt, indent=2, ensure_ascii=True))
+
+    print(f"drive backup package saved {target}")
+    print(f"records={len(records)} artifacts={len(copied)}")
+
