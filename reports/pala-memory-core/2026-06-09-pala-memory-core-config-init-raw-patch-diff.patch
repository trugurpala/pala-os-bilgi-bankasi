         path.mkdir(parents=True, exist_ok=True)
 
 
+def load_config() -> dict[str, Any]:
+    if not CONFIG_PATH.exists():
+        return {}
+    try:
+        data = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
+    except json.JSONDecodeError:
+        return {}
+    return data if isinstance(data, dict) else {}
+
+
+def write_config(config: dict[str, Any]) -> None:
+    CONFIG_PATH.write_text(json.dumps(config, indent=2, ensure_ascii=True), encoding="utf-8")
+
+
+def config_value(key: str) -> Any:
+    return load_config().get(key)
+
+
+def configured_path(value: str | None, env_name: str, config_key: str, default: Path) -> Path:
+    configured = value or os.environ.get(env_name) or config_value(config_key)
+    return Path(str(configured)).expanduser().resolve() if configured else default
+
+
+def init_config(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    if CONFIG_PATH.exists() and not args.force:
+        raise SystemExit(f"config already exists: {CONFIG_PATH}. Use --force to overwrite.")
+
+    knowledge_bank = Path(args.knowledge_bank).expanduser().resolve() if args.knowledge_bank else DEFAULT_KNOWLEDGE_BANK
+    drive_backup = Path(args.drive_target).expanduser().resolve() if args.drive_target else DEFAULT_DRIVE_BACKUP
+    mobile_share = Path(args.mobile_share).expanduser().resolve() if args.mobile_share else Path.home() / "Documents" / "Pala Mobile Shares"
+
+    if args.create_targets:
+        knowledge_bank.mkdir(parents=True, exist_ok=True)
+        drive_backup.mkdir(parents=True, exist_ok=True)
+        mobile_share.mkdir(parents=True, exist_ok=True)
+
+    config = {
+        "version": CONFIG_VERSION,
+        "knowledge_bank_path": str(knowledge_bank),
+        "drive_backup_path": str(drive_backup),
+        "mobile_share_path": str(mobile_share),
+        "dashboard_host": args.dashboard_host,
+        "dashboard_port": args.dashboard_port,
+    }
+    write_config(config)
+    print(f"config saved {CONFIG_PATH.relative_to(ROOT)}")
+    print(f"knowledge_bank_path={knowledge_bank}")
+    print(f"drive_backup_path={drive_backup}")
+    print(f"mobile_share_path={mobile_share}")
+
+
