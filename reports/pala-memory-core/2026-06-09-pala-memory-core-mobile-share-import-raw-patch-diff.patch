@@ -512,6 +512,115 @@ def import_chatgpt_export(args: argparse.Namespace) -> None:
     print(f"imported {imported} record(s) from {source}")
 
 
+def import_mobile_share(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    source = Path(args.path).expanduser().resolve()
+    if not source.exists():
+        raise SystemExit(f"mobile share path not found: {source}")
+
+    entries, attachments = collect_mobile_share_entries(source, args.max_chars)
+    imported = 0
+    tags = ["mobile-share", *(args.tag or [])]
+    for title, text in entries:
+        if imported >= args.max_records:
+            break
+        clean = text.strip()
+        if not clean:
+            continue
+        write_record(
+            argparse.Namespace(
+                title=(args.title or f"Mobile share: {title}")[:120],
+                text=clean[: args.max_chars],
+                text_file=None,
+                summary=args.summary,
+                source="mobile",
+                project=args.project,
+                tag=tags,
+                decision=[],
+                task=[],
+                file=[],
+                evidence=[{"kind": "file", "value": str(source)}],
+            )
+        )
+        imported += 1
+
+    if attachments:
+        write_record(
+            argparse.Namespace(
+                title=(args.title or "Mobile share attachments")[:120],
+                text=f"Imported {len(attachments)} attachment(s) from {source}",
+                text_file=None,
+                summary=args.summary,
+                source="mobile",
+                project=args.project,
+                tag=tags,
+                decision=[],
+                task=[],
+                file=[str(path) for path in attachments],
+                evidence=[{"kind": "file", "value": str(source)}],
+            )
+        )
+
+    print(f"imported {imported} text record(s) and {len(attachments)} attachment file(s) from {source}")
+
+
+def collect_mobile_share_entries(source: Path, max_chars: int) -> tuple[list[tuple[str, str]], list[Path]]:
+    text_suffixes = {".json", ".html", ".htm", ".md", ".txt"}
+    attachment_suffixes = {".pdf", ".png", ".jpg", ".jpeg", ".gif", ".webp", ".docx", ".pptx", ".xlsx"}
+    entries: list[tuple[str, str]] = []
+    attachments: list[Path] = []
+
+    def handle_file(path: Path) -> None:
+        suffix = path.suffix.lower()
+        if suffix in text_suffixes:
+            entries.extend(parse_import_file(path.name, path.read_bytes(), max_chars))
+        elif suffix in attachment_suffixes:
+            attachments.append(path)
+
+    if source.is_dir():
+        for path in sorted(source.rglob("*")):
+            if path.is_file():
+                handle_file(path)
+        return entries, attachments
+
+    if source.suffix.lower() == ".zip":
+        extract_dir = DATA / "inbox" / f"mobile-share-{stamp()}"
+        extract_dir.mkdir(parents=True, exist_ok=True)
+        with zipfile.ZipFile(source) as archive:
+            for member in sorted(archive.namelist()):
+                if member.endswith("/"):
+                    continue
+                suffix = Path(member).suffix.lower()
+                raw = archive.read(member)
+                name = safe_filename(Path(member).name)
+                if suffix in text_suffixes:
+                    entries.extend(parse_import_file(name, raw, max_chars))
+                elif suffix in attachment_suffixes:
+                    target = unique_path(extract_dir / name)
+                    target.write_bytes(raw)
+                    attachments.append(target)
+        return entries, attachments
+
+    handle_file(source)
+    return entries, attachments
+
+
+def safe_filename(value: str) -> str:
+    clean = "".join(char if char.isalnum() or char in [".", "-", "_"] else "-" for char in value)
+    return clean.strip(".-") or "shared-file"
+
+
+def unique_path(path: Path) -> Path:
+    if not path.exists():
+        return path
+    counter = 2
+    while True:
+        candidate = path.with_name(f"{path.stem}-{counter}{path.suffix}")
+        if not candidate.exists():
+            return candidate
+        counter += 1
+
+
