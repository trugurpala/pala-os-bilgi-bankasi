+def import_chatgpt_export(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    source = Path(args.path).expanduser().resolve()
+    if not source.exists():
+        raise SystemExit(f"import path not found: {source}")
+
+    entries = collect_import_entries(source, args.max_chars)
+    imported = 0
+    tags = ["chatgpt-export", *(args.tag or [])]
+    for title, text in entries:
+        if imported >= args.max_records:
+            break
+        clean = text.strip()
+        if not clean:
+            continue
+        write_record(
+            argparse.Namespace(
+                title=title[:120] or "ChatGPT export",
+                text=clean[: args.max_chars],
+                text_file=None,
+                summary=args.summary,
+                source="chatgpt",
+                project=args.project,
+                tag=tags,
+                decision=[],
+                task=[],
+                file=[],
+            )
+        )
+        imported += 1
+    print(f"imported {imported} record(s) from {source}")
+
+
+def collect_import_entries(source: Path, max_chars: int) -> list[tuple[str, str]]:
+    if source.is_dir():
+        entries: list[tuple[str, str]] = []
+        for path in sorted(source.rglob("*")):
+            if path.is_file() and path.suffix.lower() in [".json", ".html", ".htm", ".md", ".txt"]:
+                entries.extend(parse_import_file(path.name, path.read_bytes(), max_chars))
+        return entries
+    if source.suffix.lower() == ".zip":
+        entries = []
+        with zipfile.ZipFile(source) as archive:
+            for member in sorted(archive.namelist()):
+                if member.endswith("/"):
+                    continue
+                suffix = Path(member).suffix.lower()
+                if suffix in [".json", ".html", ".htm", ".md", ".txt"]:
+                    entries.extend(parse_import_file(Path(member).name, archive.read(member), max_chars))
+        return entries
+    return parse_import_file(source.name, source.read_bytes(), max_chars)
+
+
+def parse_import_file(name: str, raw: bytes, max_chars: int) -> list[tuple[str, str]]:
+    suffix = Path(name).suffix.lower()
+    text = raw.decode("utf-8-sig", errors="replace")
+    if suffix == ".json":
+        try:
+            return parse_json_import(name, json.loads(text), max_chars)
+        except json.JSONDecodeError:
+            return [(Path(name).stem, text[:max_chars])]
+    if suffix in [".html", ".htm"]:
+        return [(Path(name).stem, html_to_text(text)[:max_chars])]
+    return [(Path(name).stem, text[:max_chars])]
+
+
+def parse_json_import(name: str, data: Any, max_chars: int) -> list[tuple[str, str]]:
+    conversations: list[tuple[str, str]] = []
+    if isinstance(data, list):
+        for index, item in enumerate(data, start=1):
+            if isinstance(item, dict) and "mapping" in item:
+                title = str(item.get("title") or f"{Path(name).stem} {index}")
+                conversations.append((title, conversation_mapping_to_text(item.get("mapping", {}))[:max_chars]))
+        if conversations:
+            return conversations
+    if isinstance(data, dict) and "mapping" in data:
+        title = str(data.get("title") or Path(name).stem)
+        return [(title, conversation_mapping_to_text(data.get("mapping", {}))[:max_chars])]
+    return [(Path(name).stem, json.dumps(data, indent=2, ensure_ascii=True)[:max_chars])]
+
+
+def conversation_mapping_to_text(mapping: Any) -> str:
+    if not isinstance(mapping, dict):
+        return ""
+    messages = []
+    for node in mapping.values():
+        if not isinstance(node, dict):
+            continue
+        message = node.get("message")
+        if not isinstance(message, dict):
+            continue
+        content = message.get("content") or {}
+        text = message_content_to_text(content)
+        if not text.strip():
+            continue
+        author = message.get("author") or {}
+        role = author.get("role", "unknown") if isinstance(author, dict) else "unknown"
+        created = message.get("create_time") or 0
+        messages.append((created or 0, f"## {role}\n\n{text.strip()}"))
+    messages.sort(key=lambda item: item[0])
+    return "\n\n".join(item[1] for item in messages)
+
+
+def message_content_to_text(content: Any) -> str:
+    if not isinstance(content, dict):
+        return str(content)
+    parts = content.get("parts")
+    if isinstance(parts, list):
+        return "\n".join(json.dumps(part, ensure_ascii=True) if isinstance(part, dict) else str(part) for part in parts)
+    if isinstance(content.get("text"), str):
+        return content["text"]
+    return json.dumps(content, ensure_ascii=True)
+
+
+class TextExtractor(html.parser.HTMLParser):
+    def __init__(self) -> None:
+        super().__init__()
+        self.parts: list[str] = []
+
+    def handle_data(self, data: str) -> None:
+        clean = data.strip()
+        if clean:
+            self.parts.append(clean)
+
+
+def html_to_text(value: str) -> str:
+    parser = TextExtractor()
+    parser.feed(value)
+    return "\n".join(parser.parts)
+
+
