     print(f"imported {imported} text record(s) and {len(attachments)} attachment file(s) from {source}")
 
 
+def watch_mobile_share(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    watch_path = Path(args.path).expanduser().resolve()
+    if not watch_path.exists():
+        raise SystemExit(f"watch path not found: {watch_path}")
+
+    state_path = DATA / "inbox" / f"mobile-watch-{hashlib.sha256(str(watch_path).encode('utf-8')).hexdigest()[:16]}.json"
+    seen = load_seen_state(state_path)
+    print(f"watching {watch_path}")
+    while True:
+        processed = 0
+        for path in scan_watch_files(watch_path):
+            fingerprint = file_fingerprint(path)
+            if fingerprint in seen:
+                continue
+            import_mobile_share(
+                argparse.Namespace(
+                    path=str(path),
+                    title=args.title,
+                    project=args.project,
+                    tag=args.tag,
+                    summary=args.summary,
+                    max_records=args.max_records,
+                    max_chars=args.max_chars,
+                )
+            )
+            seen.add(fingerprint)
+            processed += 1
+        save_seen_state(state_path, seen)
+        print(f"watch scan complete processed={processed} seen={len(seen)}")
+        if args.once:
+            break
+        time.sleep(args.interval)
+
+
+def scan_watch_files(path: Path) -> list[Path]:
+    if path.is_file():
+        return [path]
+    return sorted(item for item in path.rglob("*") if item.is_file() and not item.name.startswith(".pala-"))
+
+
+def file_fingerprint(path: Path) -> str:
+    stat = path.stat()
+    return f"{path.resolve()}|{stat.st_size}|{stat.st_mtime_ns}"
+
+
+def load_seen_state(path: Path) -> set[str]:
+    if not path.exists():
+        return set()
+    try:
+        data = json.loads(path.read_text(encoding="utf-8"))
+    except json.JSONDecodeError:
+        return set()
+    return set(data.get("seen", [])) if isinstance(data, dict) else set()
+
+
+def save_seen_state(path: Path, seen: set[str]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps({"seen": sorted(seen)}, indent=2, ensure_ascii=True), encoding="utf-8")
+
+
