+def capture_browser(args: argparse.Namespace) -> None:
+    ensure_dirs()
+    request = urllib.request.Request(args.url, headers={"User-Agent": "PalaMemoryCore/0.6"})
+    with urllib.request.urlopen(request, timeout=args.timeout) as response:
+        raw = response.read(args.max_bytes)
+        content_type = response.headers.get("content-type", "")
+
+    text = raw.decode("utf-8-sig", errors="replace")
+    if "html" in content_type.lower() or args.url.lower().endswith((".html", ".htm", "/")):
+        text = html_to_text(text)
+
+    title = args.title or f"Browser capture: {args.url}"
+    write_record(
+        argparse.Namespace(
+            title=title,
+            text=text[: args.max_chars],
+            text_file=None,
+            summary=args.summary,
+            source="browser",
+            project=args.project,
+            tag=["browser-capture", *(args.tag or [])],
+            decision=[],
+            task=[],
+            file=[],
+            evidence=[{"kind": "url", "value": args.url}],
+        )
+    )
+    print(f"captured browser url {args.url}")
+
+
