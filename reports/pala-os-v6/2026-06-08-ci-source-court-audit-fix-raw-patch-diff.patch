+async function readDefaultSourceCards(rootDir) {
+  const backlogPath = path.join(rootDir, 'docs', 'inheritance-backlog.json');
+  try {
+    const payload = JSON.parse(await fs.readFile(backlogPath, 'utf8'));
+    return Array.isArray(payload.sourceCards) ? payload.sourceCards : [];
+  } catch {
+    return [];
+  }
+}
+
+function sourceCardIdentity(card) {
+  const normalized = normalizeCard(card);
+  return [
+    normalized.originRef,
+    normalized.repoFullName,
+    normalized.evidenceUri,
+  ].filter(hasText).join('|').toLowerCase();
+}
+
+function mergeSourceCards(...cardSets) {
+  const merged = [];
+  const seen = new Set();
+
+  for (const cardSet of cardSets) {
+    for (const card of cardSet ?? []) {
+      const identity = sourceCardIdentity(card);
+      if (!identity || seen.has(identity)) {
+        continue;
+      }
+      seen.add(identity);
+      merged.push(card);
+    }
+  }
+
+  return merged;
+}
