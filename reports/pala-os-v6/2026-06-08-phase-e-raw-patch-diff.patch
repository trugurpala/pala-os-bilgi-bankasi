+  }
+
+  if (dockerEvidence.ok && dockerEvidence.healthProbe?.ok && dockerEvidence.composeUp?.ok && dockerEvidence.composeBuild?.ok) {
+    return 'PASS';
+  }
+
+  const combinedError = [
+    dockerEvidence.reason,
+    dockerEvidence.dockerVersion?.stderr,
+    dockerEvidence.composeBuild?.stderr,
+    dockerEvidence.composeUp?.stderr,
+    dockerEvidence.composeDown?.stderr,
+  ].filter(Boolean).join(' ');
+
+  if (/dockerDesktopLinuxEngine|daemon|connect to the docker API|pipe/i.test(combinedError)) {
+    return 'NOT_AVAILABLE_WITH_REASON';
+  }
+
+  if (dockerEvidence.composeConfig?.ok || dockerEvidence.composeServices?.ok) {
+    return 'PARTIAL';
+  }
+
+  return 'BLOCKED';
+}
+
+function githubTruthStatus(github) {
+  if (github?.configured) {
+    return 'PASS';
+  }
+
+  if (github?.detectedOnly) {
+    return 'PARTIAL';
+  }
+
+  return 'NOT_AVAILABLE_WITH_REASON';
+}
+
+export function buildDashboardTruthContract(appState) {
+  const sourceStatus = normalizeTruthStatus(appState.sourceStampGate?.status);
+  const dockerStatus = dockerTruthStatus(appState.dockerEvidence);
+  const tokenEstimated = true;
+  const hasLedger = Array.isArray(appState.ledger) && appState.ledger.length > 0;
+  const hasSourceCards = Array.isArray(appState.sourceCards) && appState.sourceCards.length > 0;
+  const hasJobRuns = Array.isArray(appState.jobRuns) && appState.jobRuns.length > 0;
+  const hasMcpRegistry = (appState.skillRegistrySummary?.total ?? 0) > 0;
+  const benchmarkBlocked = (appState.benchmarkSummary?.byStatus?.blocked ?? 0) > 0;
+  const releaseBlocked = appState.court?.decision === 'RELEASE_BLOCKED' || appState.court?.ownerApproved !== true;
+
+  const panels = [
+    panel({
+      id: 'overview',
+      panel: 'Overview',
+      status: releaseBlocked ? 'RELEASE_BLOCKED' : sourceStatus === 'PASS' && hasLedger ? 'PASS' : 'PARTIAL',
+      dataSource: 'buildAppState.summary + court + sourceStampGate',
+      evidenceSource: 'SQLite standards/evidence counts, source cards, ledger, court',
+      fallbackState: 'RELEASE_BLOCKED',
+      passCondition: 'Court not release-blocked, source gate PASS, ledger has evidence.',
+      truthRisk: 'High: overview can hide downstream blockers if it is greener than child panels.',
+      statusMapping: 'owner approval missing => RELEASE_BLOCKED; missing evidence => PARTIAL.',
+      evidencePresent: hasLedger && hasSourceCards,
+    }),
+    panel({
+      id: 'mission-control',
+      panel: 'Mission Control',
+      status: hasJobRuns ? 'PARTIAL' : 'NOT_AVAILABLE_WITH_REASON',
+      dataSource: 'route, nextActions, jobRuns, runs',
+      evidenceSource: 'SQLite command_runs and job_runs',
+      fallbackState: 'NOT_AVAILABLE_WITH_REASON',
+      passCondition: 'Mission/run ledger proves active mission state and no blocking court state.',
+      truthRisk: 'Medium: route text can look decisive without mission evidence.',
+      statusMapping: 'missing run/job evidence => NOT_AVAILABLE_WITH_REASON; live-but-not-release-proof => PARTIAL.',
+      evidencePresent: hasJobRuns,
+    }),
+    panel({
+      id: 'ci-court',
+      panel: 'CI Court',
+      status: githubTruthStatus(appState.github),
+      dataSource: 'github bridge status and GitHub audit evidence',
+      evidenceSource: 'GitHub CLI/API readback and workflow runs',
+      fallbackState: 'NOT_AVAILABLE_WITH_REASON',
+      passCondition: 'GitHub governance readback configured and required checks proven.',
+      truthRisk: 'High: CI green without branch protection/review can be fake governance.',
+      statusMapping: 'unknown GitHub state => NOT_AVAILABLE_WITH_REASON; detected-only => PARTIAL.',
+      evidencePresent: Boolean(appState.github?.configured || appState.github?.detectedOnly),
+    }),
+    panel({
+      id: 'evidence-center',
+      panel: 'Evidence Center',
+      status: hasLedger && hasSourceCards ? 'PASS' : 'PARTIAL',
+      dataSource: 'ledger, sourceCards, evidenceSprint',
+      evidenceSource: 'SQLite ledger records and source-card table',
+      fallbackState: 'PARTIAL',
+      passCondition: 'Ledger has records and source cards exist.',
+      truthRisk: 'High: empty evidence must never display PASS.',
+      statusMapping: 'empty ledger or no source cards => PARTIAL.',
+      evidencePresent: hasLedger && hasSourceCards,
+    }),
+    panel({
+      id: 'source-court',
+      panel: 'Source Court',
+      status: sourceStatus,
+      dataSource: 'sanitizeSourceCourtAudit(buildSourceCourtAudit())',
+      evidenceSource: 'Source Court summary and sourceStampGate',
+      fallbackState: 'NOT_AVAILABLE_WITH_REASON',
+      passCondition: 'sourceStampGate PASS with no release-blocking chain gaps.',
+      truthRisk: 'High: raw legacy/source files must not leak into dashboard state.',
+      statusMapping: 'sourceStampGate BLOCKED => BLOCKED; PARTIAL => PARTIAL; missing => NOT_AVAILABLE_WITH_REASON.',
+      evidencePresent: Boolean(appState.sourceCourtAudit?.summary),
+    }),
+    panel({
+      id: 'skill-registry',
+      panel: 'Skill Registry',
+      status: hasMcpRegistry ? 'PASS' : 'NOT_AVAILABLE_WITH_REASON',
+      dataSource: 'seed skill registry',
+      evidenceSource: 'skills/registry/seed-skills.json via loadSeedSkillRegistry',
+      fallbackState: 'NOT_AVAILABLE_WITH_REASON',
+      passCondition: 'Seed registry loads and legacy registry is not default-loaded.',
+      truthRisk: 'Medium: legacy skill index must not be treated as active skills.',
+      statusMapping: 'missing registry => NOT_AVAILABLE_WITH_REASON; seed registry loaded => PASS.',
+      evidencePresent: hasMcpRegistry,
+    }),
+    panel({
+      id: 'mcp-health',
+      panel: 'MCP Health',
+      status: hasMcpRegistry ? 'PARTIAL' : 'NOT_AVAILABLE_WITH_REASON',
+      dataSource: 'MCP read registry and CLI/stdio proof',
+      evidenceSource: 'mcp health CLI/test output; no live MCP process stored in dashboard state',
+      fallbackState: 'NOT_AVAILABLE_WITH_REASON',
+      passCondition: 'MCP health command or stdio proof is attached to dashboard state.',
+      truthRisk: 'Medium: registry presence is not the same as live MCP health.',
+      statusMapping: 'registry only => PARTIAL; no registry => NOT_AVAILABLE_WITH_REASON.',
+      evidencePresent: hasMcpRegistry,
+    }),
+    panel({
+      id: 'docker-boot',
+      panel: 'Docker Boot',
+      status: dockerStatus,
+      dataSource: 'latest .pala/evidence/docker smoke JSON',
+      evidenceSource: 'docker version, compose config/build/up/health/down evidence',
+      fallbackState: 'NOT_AVAILABLE_WITH_REASON',
+      passCondition: 'Docker daemon available, compose build/up succeeds, API health passes, compose down succeeds.',
+      truthRisk: 'High: compose config alone is not runtime proof.',
+      statusMapping: 'no docker evidence or daemon unavailable => NOT_AVAILABLE_WITH_REASON; compose-only => PARTIAL.',
+      evidencePresent: Boolean(appState.dockerEvidence),
+    }),
+    panel({
+      id: 'benchmark-radar',
+      panel: 'Benchmark Radar',
+      status: benchmarkBlocked ? 'PARTIAL' : (appState.benchmarkSummary?.total ?? 0) > 0 ? 'PARTIAL' : 'NOT_AVAILABLE_WITH_REASON',
+      dataSource: 'benchmark/benchmark-state.json',
+      evidenceSource: 'benchmark categories and evidence counts',
+      fallbackState: 'NOT_AVAILABLE_WITH_REASON',
+      passCondition: 'Fixture-backed benchmark suite has no blocked category.',
+      truthRisk: 'Medium: benchmark placeholders can look like proof.',
+      statusMapping: 'blocked or fixture-missing benchmark => PARTIAL; no state => NOT_AVAILABLE_WITH_REASON.',
+      evidencePresent: (appState.benchmarkSummary?.total ?? 0) > 0,
+    }),
+    panel({
+      id: 'token-economy',
+      panel: 'Token Economy',
+      status: 'PARTIAL',
+      dataSource: 'tokenBudget and tokenSnapshots',
+      evidenceSource: 'SQLite token_snapshots or deterministic estimate',
+      fallbackState: 'PARTIAL',
+      passCondition: 'Measured token accounting exists with confidence metadata.',
+      truthRisk: 'Medium: estimates can be mistaken for measured savings.',
+      statusMapping: 'estimated token accounting => PARTIAL.',
+      evidencePresent: Boolean(appState.tokenBudget),
+      estimated: tokenEstimated,
+    }),
+    panel({
+      id: 'release-court',
+      panel: 'Release Court',
+      status: releaseBlocked ? 'RELEASE_BLOCKED' : 'PASS',
+      dataSource: 'evaluateCourt()',
+      evidenceSource: 'owner approval, required standards, source cards, ledger, sourceStampGate',
+      fallbackState: 'RELEASE_BLOCKED',
+      passCondition: 'Owner approval present, no blocked required standards, source cards, ledger evidence, source gate not blocked.',
+      truthRisk: 'Critical: release must never turn green without owner approval.',
+      statusMapping: 'owner approval missing => RELEASE_BLOCKED.',
+      evidencePresent: Boolean(appState.court),
+    }),
+  ];
+
+  const overall = releaseBlocked
+    ? 'RELEASE_BLOCKED'
+    : worstTruthStatus(panels.map((item) => item.status));
+  const byStatus = panels.reduce((summary, item) => {
+    summary[item.status] = (summary[item.status] ?? 0) + 1;
+    return summary;
+  }, {});
+
+  return {
+    status: overall,
+    generatedAt: new Date().toISOString(),
+    rules: {
+      unknown: 'NOT_AVAILABLE_WITH_REASON',
+      evidenceMissing: 'PARTIAL',
+      ownerApprovalMissing: 'RELEASE_BLOCKED',
+      dockerDaemonMissing: 'Docker Boot cannot be PASS',
+      sourceCourtPartial: 'Source Court panel remains PARTIAL',
+      legacyBoundary: 'Dashboard reads only sanitized Source Court summary',
+      tokenEconomy: 'Estimated token values must be marked estimated',
+    },
+    summary: {
+      panelCount: panels.length,
+      byStatus,
+      highestRiskStatus: overall,
+      releaseBlocked,
+      allPanelStatuses: panels.map((item) => item.status),
+      overallNotGreenerThanPanels: truthStatusRank(overall) >= Math.max(...panels.map((item) => truthStatusRank(item.status))),
+    },
+    panels,
   };
 }
 
