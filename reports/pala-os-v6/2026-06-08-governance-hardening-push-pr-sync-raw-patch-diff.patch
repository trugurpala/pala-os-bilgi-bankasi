+  'AGENTS.md',
+];
+
+function statusBucket(status) {
+  if (status === 'active') return 'active';
+  if (status === 'owner-gated') return 'ownerGated';
+  if (status === 'active-watch' || status === 'needs-hardening') return 'watch';
+  return 'blocked';
+}
+
+export function buildCoreFoundationRadar(state) {
+  const standardsTotal = state.summary?.total ?? 0;
+  const required = state.summary?.required ?? state.summary?.byPolicy?.required ?? 0;
+  const recommended = state.summary?.recommended ?? state.summary?.byPolicy?.recommended ?? 0;
+  const machineGates = state.summary?.machineGates ?? 0;
