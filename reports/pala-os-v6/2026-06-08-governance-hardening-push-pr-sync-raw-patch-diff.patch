+test('github audit emits machine-readable governance gates', async () => {
+  const output = execFileSync('powershell', [
+    '-NoProfile',
+    '-ExecutionPolicy',
+    'Bypass',
+    '-File',
+    path.join(repoRoot, 'scripts', 'pala_github_gate_audit.ps1'),
+  ], {
+    cwd: repoRoot,
+    env: {
+      ...process.env,
+      PALA_OPEN_BROWSER: '0',
+    },
+    encoding: 'utf8',
+  });
+  const audit = JSON.parse(output);
+
+  assert.equal(audit.ok, true);
+  assert.ok(['PASS', 'PARTIAL', 'BLOCKED'].includes(audit.summary.status));
+  assert.ok(['PASS', 'PARTIAL', 'BLOCKED'].includes(audit.gates.branchProtection.status));
+  assert.ok(['PASS', 'PARTIAL', 'BLOCKED'].includes(audit.gates.requiredChecks.status));
+  assert.ok(['PASS', 'PARTIAL', 'BLOCKED'].includes(audit.gates.review.status));
+  assert.equal(audit.gates.localPolicy.status, 'PASS');
+
+  if (audit.gates.branchProtection.status === 'BLOCKED') {
+    assert.equal(audit.summary.blocker, 'BRANCH_PROTECTION_BLOCKED');
+  }
+});
