+  const eventCount = state.events?.length ?? 0;
+  const jobCount = state.jobRuns?.length ?? 0;
+  const blockedRequired = state.summary?.blocked ?? 0;
+  const courtDecision = state.court?.decision ?? 'UNKNOWN';
+  const ownerApproved = Boolean(state.court?.ownerApproved);
+
+  const components = [
+    {
+      id: 'sak-cli',
+      title: 'sak CLI',
+      layer: 'command',
+      status: runCount > 0 ? 'active' : 'needs-hardening',
+      verdict: runCount > 0 ? 'GECERLI' : 'KANIT YOK',
+      currentEvidence: `${runCount} command runs recorded`,
+      decision: 'Keep as the operator entrypoint; add new actions as audited subcommands, not hidden automation.',
+      noFakeControl: 'Every meaningful command is wrapped with run start/finish ledger evidence.',
+      requiredNextProof: 'Add core audit command and keep command output in test coverage.',
+      sourceRefs: ['README.md', 'src/cli.js', 'docs/world-standards-map.md'],
+    },
+    {
+      id: 'sqlite-evidence-ledger',
+      title: 'SQLite Evidence Ledger',
+      layer: 'database',
+      status: ledgerCount > 0 ? 'active-watch' : 'needs-hardening',
+      verdict: ledgerCount > 0 ? 'KISMEN' : 'KANIT YOK',
+      currentEvidence: `${ledgerCount} JSONL records; ${eventCount} recent DB events`,
+      decision: 'Keep SQLite as the local ledger database, but monitor Node built-in SQLite maturity and backup/export needs.',
+      noFakeControl: 'DB tables and append-only JSONL both receive events, tool usage, jobs, gate decisions, and runs.',
+      requiredNextProof: 'Add backup/export and ledger parse-failure audit before calling the ledger hardened.',
+      sourceRefs: ['https://nodejs.org/api/sqlite.html', 'src/db.js', 'src/ledger.js'],
+    },
+    {
+      id: 'standards-policy-engine',
+      title: '60 Standards Policy Engine',
+      layer: 'policy',
+      status: standardsTotal === 60 && required === 42 && recommended === 18 && machineGates >= 15 ? 'active' : 'needs-hardening',
+      verdict: standardsTotal === 60 ? 'GECERLI' : 'BASARISIZ',
+      currentEvidence: `${standardsTotal} standards; ${required} required; ${recommended} recommended; ${machineGates} machine gates`,
+      decision: 'Keep the 60-standard catalog as the first policy battalion; future standards enter backlog first, then owner-reviewed catalog.',
+      noFakeControl: 'Required standards without evidence remain blocked; recommended standards do not count as release green.',
+      requiredNextProof: 'Keep source refs, evidence hints, and machine-gate order tested whenever the catalog changes.',
+      sourceRefs: ['https://csrc.nist.gov/pubs/sp/800/218/final', 'https://slsa.dev/spec/latest/', 'src/standards.js'],
+    },
+    {
+      id: 'source-card-gate',
+      title: 'Source Card Gate',
+      layer: 'import-control',
+      status: sourceCardCount > 0 ? 'active' : 'needs-hardening',
+      verdict: sourceCardCount > 0 ? 'GECERLI' : 'KANIT YOK',
+      currentEvidence: `${sourceCardCount} source cards in local state`,
+      decision: 'Keep external code and old Pala copies behind quarantine/source-card decisions before any adapter import.',
+      noFakeControl: 'Ingest writes source-card ledger evidence; external source is not core truth by default.',
+      requiredNextProof: 'Require license, commit pin, visibility, decision, risk, and allowed layer before upstream adoption.',
+      sourceRefs: ['docs/oss-upstream-matrix.md', 'src/bootstrap.js', 'src/db.js'],
+    },
+    {
+      id: 'court-release-gate',
+      title: 'Court / Release Gate',
+      layer: 'release-control',
+      status: courtDecision === 'RELEASE_BLOCKED' && !ownerApproved ? 'owner-gated' : blockedRequired > 0 ? 'needs-hardening' : 'active-watch',
+      verdict: courtDecision === 'RELEASE_BLOCKED' ? 'BASARISIZ' : 'KISMEN',
+      currentEvidence: `${courtDecision}; ownerApproved=${ownerApproved}; blockedRequired=${blockedRequired}`,
+      decision: 'Keep release blocked unless owner approval, source cards, ledger evidence, and zero blocked required standards all exist.',
+      noFakeControl: 'Release PASS cannot be produced from dashboard optimism; it is computed from owner, standards, source, and ledger evidence.',
+      requiredNextProof: 'Enable GitHub branch protection/rulesets before treating current-head CI as release sufficient.',
+      sourceRefs: ['https://docs.github.com/en/repositories/configuring-branches-and-merges-in-your-repository/managing-protected-branches', 'src/policy.js', 'src/cli.js'],
+    },
+    {
+      id: 'cron-watchers',
+      title: 'Cron Watchers',
+      layer: 'operations',
+      status: jobCount > 0 ? 'active' : 'needs-hardening',
+      verdict: jobCount > 0 ? 'GECERLI' : 'KANIT YOK',
+      currentEvidence: `${jobCount} recent job runs; ${cronWatchers} standards carry cron watcher flags`,
+      decision: 'Keep cron read/evidence-oriented. It may recommend actions but must not rewrite repo files or perform risky writes silently.',
+      noFakeControl: 'Cron writes watcher jobs and token snapshots to the ledger; it does not mark release ready.',
+      requiredNextProof: 'Add provider drift and core-foundation watch outputs to routine cron evidence.',
+      sourceRefs: ['src/bootstrap.js', 'docs/world-standards-map.md'],
+    },
+  ];
+
+  const byStatus = {};
+  const byVerdict = {};
+  for (const component of components) {
+    byStatus[component.status] = (byStatus[component.status] ?? 0) + 1;
+    byVerdict[component.verdict] = (byVerdict[component.verdict] ?? 0) + 1;
+  }
+
+  return {
+    version: 1,
+    status: 'control-target',
+    noFakeDone: 'Core foundation radar is not release approval. It states which core parts are active, watched, owner-gated, or still needing hardening.',
+    references: CORE_FOUNDATION_REFERENCES,
+    summary: {
+      total: components.length,
+      active: components.filter((component) => statusBucket(component.status) === 'active').length,
+      watch: components.filter((component) => statusBucket(component.status) === 'watch').length,
+      ownerGated: components.filter((component) => statusBucket(component.status) === 'ownerGated').length,
+      blocked: components.filter((component) => statusBucket(component.status) === 'blocked').length,
+      byStatus,
+      byVerdict,
+    },
+    components,
+  };
+}
