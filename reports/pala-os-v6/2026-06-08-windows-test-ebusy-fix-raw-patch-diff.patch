+async function rm(targetPath, options) {
+  const retryableCodes = new Set(['EBUSY', 'EPERM', 'ENOTEMPTY']);
+  let lastError = null;
+
+  for (let attempt = 0; attempt < 8; attempt += 1) {
+    try {
+      await fsRm(targetPath, options);
+      return;
+    } catch (error) {
+      lastError = error;
+      if (!retryableCodes.has(error?.code) || attempt === 7) {
+        throw error;
+      }
+      await delay(100 * (attempt + 1));
+    }
+  }
+
+  throw lastError;
+}
