+  t.after(async () => {
+    await rm(root, { recursive: true, force: true });
+  });
+
+  await mkdir(path.join(root, 'src'), { recursive: true });
+  await mkdir(path.join(root, 'legacy', 'pala-os', 'source', 'src'), { recursive: true });
+  await writeFile(path.join(root, 'src', 'stamp-only.js'), [
+    '/**',
+    ' * @palaSourceRef legacy/pala-os/source/src/stamp-only.js',
+    ' * @palaSourceRepo trugurpala/pala-os',
+    ' * @palaCourtDecision ADAPT',
+    ' * @palaCourtId MIGRATION-V6-001',
+    ' * @palaRewritePolicy Adapted for v6 strict governance, not blind copied.',
+    ' * @palaSavedEstimate 3d_estimated',
+    ' */',
+    'export const adapted = true;',
+    '',
+  ].join('\n'));
+  await writeFile(path.join(root, 'src', 'card-only.js'), 'export const cardOnly = "legacy";\n');
+  await writeFile(path.join(root, 'legacy', 'pala-os', 'source', 'src', 'card-only.js'), 'export const cardOnly = "legacy";\n');
+
+  const card = {
+    origin_type: 'local-path',
+    origin_ref: 'legacy/pala-os/source',
+    repo_full_name: 'trugurpala/pala-os',
+    visibility: 'local',
+    commit_sha: 'archive',
+    license: 'MIT',
+    decision: 'QUARANTINE',
+    risk_level: 'medium',
+    allowed_layer: 'adapter',
+    summary: 'legacy source under review',
+  };
+  const withStampOnly = await buildSourceCourtAudit({
+    rootDir: root,
+    sourceCards: [],
+    courtDecisions: [],
+    legacyMode: 'explicit',
+  });
+  const withCardOnly = await buildSourceCourtAudit({
+    rootDir: root,
+    sourceCards: [card],
+    courtDecisions: [],
+    legacyMode: 'explicit',
+  });
+
+  const stampOnly = withStampOnly.files.find((file) => file.path === 'src/stamp-only.js');
+  const cardOnly = withCardOnly.files.find((file) => file.path === 'src/card-only.js');
+
+  assert.equal(stampOnly?.classification, 'LEGACY_ADAPTED');
+  assert.equal(stampOnly?.status, 'BLOCKED');
+  assert.ok(stampOnly?.missingRequirements.includes('sourceCard'));
+  assert.ok(stampOnly?.missingRequirements.includes('courtDecision'));
+  assert.equal(cardOnly?.classification, 'LEGACY_ADAPTED');
+  assert.equal(cardOnly?.status, 'BLOCKED');
+  assert.ok(cardOnly?.missingRequirements.includes('sourceStamp'));
+});
