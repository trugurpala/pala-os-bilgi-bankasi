+    '# Source stamp contract',
+    '',
+    '```ts',
+    '/**',
+    ' * @palaSourceRef legacy/pala-os/source/src/example.js',
+    ' * @palaSourceRepo trugurpala/pala-os',
+    ' * @palaCourtDecision ADAPT',
+    ' */',
+    '```',
+    '',
+  ].join('\n'));
+  await writeFile(path.join(root, 'src', 'copied.js'), 'export const copied = "legacy";\n');
+  await writeFile(path.join(root, 'legacy', 'pala-os', 'source', 'src', 'copied.js'), 'export const copied = "legacy";\n');
+  await writeFile(path.join(root, '.pala', 'runtime', 'ignored.js'), 'ignored\n');
+  await writeFile(path.join(root, 'node_modules', 'pkg', 'ignored.js'), 'ignored\n');
+  await writeFile(path.join(root, 'dist', 'ignored.js'), 'ignored\n');
+
+  const audit = await buildSourceCourtAudit({
+    rootDir: root,
