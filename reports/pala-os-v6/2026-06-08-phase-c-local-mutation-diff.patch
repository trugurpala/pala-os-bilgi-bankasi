+import { createHash } from 'node:crypto';
+import fs from 'node:fs/promises';
+import path from 'node:path';
+
+export const SOURCE_CLASSES = {
+  PALA_ORIGINAL: 'PALA_ORIGINAL',
+  LEGACY_ADAPTED: 'LEGACY_ADAPTED',
+  OSS_ADAPTED: 'OSS_ADAPTED',
+  REFERENCE_ONLY: 'REFERENCE_ONLY',
+  GOVERNANCE_DOC: 'GOVERNANCE_DOC',
+};
+
+export const SOURCE_STATUSES = {
+  PASS: 'PASS',
+  PARTIAL: 'PARTIAL',
+  BLOCKED: 'BLOCKED',
+  NOT_AVAILABLE_WITH_REASON: 'NOT_AVAILABLE_WITH_REASON',
+};
+
+const ACTIVE_DIRS = ['src', 'scripts', 'docs', 'plans', 'prompts'];
+const ROOT_GOVERNANCE_DOCS = new Set([
+  'README.md',
+  'AGENTS.md',
+  'PALA_RULES.md',
+  'SECURITY.md',
+  'ARCHITECTURE.md',
+]);
+const REQUIRED_STAMP_FIELDS = [
+  'palaSourceRef',
+  'palaSourceRepo',
+  'palaCourtDecision',
+  'palaCourtId',
+  'palaRewritePolicy',
+  'palaSavedEstimate',
+];
+const COURT_DECISIONS = new Set(['ADOPT', 'ADAPT', 'IMPORT_LATER', 'QUARANTINE', 'REJECT', 'ADAPT_PATTERN']);
+const BUILD_ARTIFACT_DIRS = new Set(['dist', 'build', 'coverage', '.next', 'out']);
+const LEGACY_MODE_EXPLICIT = 'explicit';
+const LEGACY_MODE_DISABLED = 'disabled';
+
+function toPosix(value) {
+  return String(value).replaceAll(path.sep, '/').replaceAll('\\', '/');
+}
+
+function relativeTo(rootDir, targetPath) {
+  return toPosix(path.relative(rootDir, targetPath));
+}
+
+function normalizeCard(card) {
+  return {
+    id: card.id ?? null,
+    originType: card.origin_type ?? card.originType ?? '',
+    originRef: card.origin_ref ?? card.originRef ?? '',
+    repoFullName: card.repo_full_name ?? card.repoFullName ?? '',
+    visibility: card.visibility ?? '',
+    commitSha: card.commit_sha ?? card.commitSha ?? '',
+    license: card.license ?? '',
+    decision: card.decision ?? '',
+    riskLevel: card.risk_level ?? card.riskLevel ?? '',
+    allowedLayer: card.allowed_layer ?? card.allowedLayer ?? '',
+    summary: card.summary ?? '',
+    evidenceUri: card.evidence_uri ?? card.evidenceUri ?? '',
+  };
+}
+
+function hasText(value) {
+  return String(value ?? '').trim().length > 0;
+}
+
+function sourceCardFieldsComplete(card) {
+  if (!card) {
+    return false;
+  }
+  const normalized = normalizeCard(card);
+  return [
+    normalized.originRef || normalized.repoFullName,
+    normalized.visibility,
+    normalized.commitSha || normalized.originRef,
+    normalized.license || 'NOT_AVAILABLE_WITH_REASON',
+    normalized.decision,
+    normalized.riskLevel,
+    normalized.allowedLayer,
+    normalized.summary || normalized.evidenceUri,
+  ].every(hasText);
+}
+
+function isExcludedPath(relativePath) {
+  const normalized = toPosix(relativePath);
+  const [first] = normalized.split('/');
+
+  if (!normalized || normalized.startsWith('../')) {
+    return true;
+  }
+  if (normalized.startsWith('legacy/') || normalized === 'legacy') {
+    return true;
+  }
+  if (normalized.startsWith('.git/') || normalized === '.git') {
+    return true;
+  }
+  if (normalized.startsWith('node_modules/') || normalized === 'node_modules') {
+    return true;
+  }
+  if (normalized.startsWith('.pala/db/') || normalized.startsWith('.pala/runtime/')) {
+    return true;
+  }
+  return BUILD_ARTIFACT_DIRS.has(first);
+}
+
+async function pathExists(targetPath) {
+  try {
+    await fs.access(targetPath);
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+async function listFilesRecursive(rootDir, startPath, { respectExcludes = true } = {}) {
+  const files = [];
+  if (!(await pathExists(startPath))) {
+    return files;
+  }
+
+  const entries = await fs.readdir(startPath, { withFileTypes: true });
+  for (const entry of entries) {
+    const fullPath = path.join(startPath, entry.name);
+    const relativePath = relativeTo(rootDir, fullPath);
+    if (respectExcludes && isExcludedPath(relativePath)) {
+      continue;
+    }
+    if (entry.isDirectory()) {
+      files.push(...await listFilesRecursive(rootDir, fullPath, { respectExcludes }));
+      continue;
+    }
+    if (entry.isFile()) {
+      files.push(fullPath);
+    }
+  }
+
+  return files;
+}
+
+async function discoverActiveFiles(rootDir) {
+  const discovered = new Set();
+
+  for (const activeDir of ACTIVE_DIRS) {
+    const dirPath = path.join(rootDir, activeDir);
+    for (const filePath of await listFilesRecursive(rootDir, dirPath)) {
+      discovered.add(filePath);
+    }
+  }
+
+  for (const docName of ROOT_GOVERNANCE_DOCS) {
+    const docPath = path.join(rootDir, docName);
+    if (await pathExists(docPath)) {
+      discovered.add(docPath);
+    }
+  }
+
+  return [...discovered].sort((a, b) => relativeTo(rootDir, a).localeCompare(relativeTo(rootDir, b)));
+}
+
+async function discoverLegacyFiles(rootDir) {
+  const legacyRoot = path.join(rootDir, 'legacy');
+  return listFilesRecursive(rootDir, legacyRoot, { respectExcludes: false });
+}
+
+function hashContent(content) {
+  return createHash('sha256').update(content).digest('hex');
+}
+
+function buildLegacyBoundary({ legacyMode, files = [] }) {
+  if (legacyMode !== LEGACY_MODE_EXPLICIT) {
+    return {
+      status: SOURCE_STATUSES.NOT_AVAILABLE_WITH_REASON,
+      mode: LEGACY_MODE_DISABLED,
+      files: 0,
+      reason: 'legacy archive is quarantined and not read by default product surfaces',
+      allowedReaders: ['source audit', 'legacy audit', 'legacy archive', 'legacy skills index'],
+      forbiddenReaders: ['runtime', 'dashboard truth', 'docker package', 'default test discovery', 'active skill loader', 'default agent context'],
+    };
+  }
+
+  return {
+    status: files.length > 0 ? SOURCE_STATUSES.PASS : SOURCE_STATUSES.NOT_AVAILABLE_WITH_REASON,
+    mode: LEGACY_MODE_EXPLICIT,
+    files: files.length,
+    reason: files.length > 0
+      ? 'legacy archive read by explicit source-court audit'
+      : 'explicit legacy audit requested but no legacy archive files were found',
+    allowedReaders: ['source audit', 'legacy audit', 'legacy archive', 'legacy skills index'],
+    forbiddenReaders: ['runtime', 'dashboard truth', 'docker package', 'default test discovery', 'active skill loader', 'default agent context'],
+  };
+}
+
+async function buildLegacyHashIndex(rootDir, { legacyMode = LEGACY_MODE_DISABLED } = {}) {
+  if (legacyMode !== LEGACY_MODE_EXPLICIT) {
+    return {
+      index: new Map(),
+      boundary: buildLegacyBoundary({ legacyMode }),
+    };
+  }
+
+  const index = new Map();
+  const files = await discoverLegacyFiles(rootDir);
+  for (const filePath of files) {
+    const content = await fs.readFile(filePath, 'utf8').catch(() => null);
+    if (content === null) {
+      continue;
+    }
+    const hash = hashContent(content);
+    const relativePath = relativeTo(rootDir, filePath);
+    const matches = index.get(hash) ?? [];
+    matches.push(relativePath);
+    index.set(hash, matches);
+  }
+  return {
+    index,
+    boundary: buildLegacyBoundary({ legacyMode, files }),
+  };
+}
+
+export function parseSourceStamp(content) {
+  const fields = {};
+  const pattern = /@(pala[A-Za-z]+)\s+([^\r\n*]+)/g;
+  const scanContent = content.replace(/```[\s\S]*?```/g, '');
+  let match = pattern.exec(scanContent);
+  while (match) {
+    fields[match[1]] = match[2].trim();
+    match = pattern.exec(scanContent);
+  }
+
+  const missingFields = REQUIRED_STAMP_FIELDS.filter((field) => !hasText(fields[field]));
+  const present = REQUIRED_STAMP_FIELDS.some((field) => hasText(fields[field]));
+
+  return {
+    present,
+    fields,
+    requiredFields: REQUIRED_STAMP_FIELDS,
+    missingFields,
+    complete: present && missingFields.length === 0,
+  };
+}
+
+function looksLikeLegacySource(stamp) {
+  const sourceRef = String(stamp.fields.palaSourceRef ?? '').toLowerCase();
+  const sourceRepo = String(stamp.fields.palaSourceRepo ?? '').toLowerCase();
+  return [
+    sourceRef,
+    sourceRepo,
+  ].some((value) => {
+    return value.includes('legacy/pala-os')
+      || value.includes('trugurpala/pala-os:')
+      || value.endsWith('trugurpala/pala-os')
+      || /trugurpala\/pala-os-v[0-5](?:$|[:/])/.test(value);
+  });
+}
+
+function hasOssSourceStamp(stamp) {
+  if (!stamp.present) {
+    return false;
+  }
+  return !looksLikeLegacySource(stamp);
+}
+
+function isGovernanceDoc(relativePath, content) {
+  if (isCodeSurface(relativePath)) {
+    return false;
+  }
+
+  const basename = path.basename(relativePath);
+  if (ROOT_GOVERNANCE_DOCS.has(basename) && !relativePath.includes('/')) {
+    return true;
+  }
+
+  const lowerPath = relativePath.toLowerCase();
+  const lowerContent = content.toLowerCase();
+  return [
+    'court',
+    'release',
+    'gate',
+    'governance',
+    'source-court',
+    'source-card',
+    'world-standards',
+    'github-policy',
+    'agent-contracts',
+  ].some((token) => lowerPath.includes(token) || lowerContent.includes(token));
+}
+
+function isReferenceOnly(relativePath) {
+  const normalized = relativePath.toLowerCase();
+  return normalized.startsWith('docs/legacy/')
+    || normalized.includes('/archive/')
+    || normalized.endsWith('/reference.md');
+}
+
+function isCodeSurface(relativePath) {
+  return relativePath.startsWith('src/') || relativePath.startsWith('scripts/');
+}
+
+function classifyFile({ relativePath, content, legacyMatches, stamp }) {
+  const governanceDoc = isGovernanceDoc(relativePath, content);
+  const referenceOnly = isReferenceOnly(relativePath);
+  let adaptation = null;
+
+  if (referenceOnly) {
+    return {
+      classification: SOURCE_CLASSES.REFERENCE_ONLY,
+      adaptation: null,
+      governanceDoc: false,
+      referenceOnly: true,
+    };
+  }
+
+  if (looksLikeLegacySource(stamp) || legacyMatches.length > 0) {
+    adaptation = SOURCE_CLASSES.LEGACY_ADAPTED;
+  } else if (hasOssSourceStamp(stamp)) {
+    adaptation = SOURCE_CLASSES.OSS_ADAPTED;
+  }
+
+  if (governanceDoc) {
+    return {
+      classification: SOURCE_CLASSES.GOVERNANCE_DOC,
+      adaptation,
+      governanceDoc: true,
+      referenceOnly: false,
+    };
+  }
+
+  if (adaptation) {
+    return {
+      classification: adaptation,
+      adaptation,
+      governanceDoc: false,
+      referenceOnly: false,
+    };
+  }
+
+  return {
+    classification: SOURCE_CLASSES.PALA_ORIGINAL,
+    adaptation: null,
+    governanceDoc: false,
+    referenceOnly: false,
+  };
+}
+
+function sourceTokensForMatch({ stamp, legacyMatches }) {
+  return [
+    stamp.fields.palaSourceRef,
+    stamp.fields.palaSourceRepo,
+    ...legacyMatches,
+  ].filter(hasText).map((value) => String(value).toLowerCase());
+}
+
+function findMatchingSourceCard(sourceCards, { stamp, legacyMatches }) {
+  const tokens = sourceTokensForMatch({ stamp, legacyMatches });
+  return sourceCards.map(normalizeCard).find((card) => {
+    const cardValues = [
+      card.originRef,
+      card.repoFullName,
+      card.evidenceUri,
+    ].filter(hasText).map((value) => String(value).toLowerCase());
+
+    return cardValues.some((cardValue) => {
+      return tokens.some((token) => token.includes(cardValue) || cardValue.includes(token.split(':')[0]));
+    });
+  }) ?? null;
+}
+
+function loadCourtDecisionRows(rawDecisions) {
+  return (rawDecisions ?? []).map((decision) => ({
+    sourceRef: decision.sourceRef ?? '',
+    decision: decision.decision ?? '',
+    category: decision.category ?? '',
+    riskLevel: decision.riskLevel ?? '',
+  }));
+}
+
+async function readDefaultCourtDecisions(rootDir) {
+  const backlogPath = path.join(rootDir, 'docs', 'inheritance-backlog.json');
+  try {
+    const payload = JSON.parse(await fs.readFile(backlogPath, 'utf8'));
+    return loadCourtDecisionRows(payload.sourceCourtDecisions ?? []);
+  } catch {
+    return [];
+  }
+}
+
+function findMatchingCourtDecision(courtDecisions, { stamp, legacyMatches }) {
+  const tokens = sourceTokensForMatch({ stamp, legacyMatches });
+  const stampDecision = String(stamp.fields.palaCourtDecision ?? '').trim();
+
+  return loadCourtDecisionRows(courtDecisions).find((decision) => {
+    const sourceRef = String(decision.sourceRef ?? '').toLowerCase();
+    const decisionName = String(decision.decision ?? '').trim();
+    const sourceMatches = tokens.some((token) => {
+      const normalizedToken = token.replace('legacy/pala-os/source', 'trugurpala/pala-os');
+      return sourceRef && (normalizedToken.includes(sourceRef.split(':')[0]) || sourceRef.includes(normalizedToken.split('/source/')[0]));
+    });
+    const decisionMatches = !stampDecision || decisionName === stampDecision || COURT_DECISIONS.has(decisionName);
+    return sourceMatches && decisionMatches;
+  }) ?? null;
+}
+
+function buildValidatorLink(relativePath, contentHash) {
+  return `source-court:${relativePath}#${contentHash.slice(0, 12)}`;
+}
+
+function validateFileChain({ classification, adaptation, relativePath, stamp, sourceCard, courtDecision, validatorLink }) {
+  const effectiveAdaptation = adaptation ?? (
+    classification === SOURCE_CLASSES.LEGACY_ADAPTED || classification === SOURCE_CLASSES.OSS_ADAPTED
+      ? classification
+      : null
+  );
+  const adapted = Boolean(effectiveAdaptation);
+  const requiresStamp = effectiveAdaptation === SOURCE_CLASSES.LEGACY_ADAPTED
+    || (effectiveAdaptation === SOURCE_CLASSES.OSS_ADAPTED && isCodeSurface(relativePath));
+  const releaseEvidenceAllowed = classification !== SOURCE_CLASSES.REFERENCE_ONLY;
+  const sourceCardComplete = sourceCardFieldsComplete(sourceCard);
+  const courtDecisionComplete = Boolean(courtDecision?.decision);
+  const stampComplete = stamp.complete;
+  const missingRequirements = [];
+
+  if (adapted) {
+    if (requiresStamp && !stamp.present) {
+      missingRequirements.push('sourceStamp');
+    } else if (requiresStamp && !stampComplete) {
+      missingRequirements.push(...stamp.missingFields);
+    }
+    if (!sourceCard) {
+      missingRequirements.push('sourceCard');
+    } else if (!sourceCardComplete) {
+      missingRequirements.push('sourceCardRequiredFields');
+    }
+    if (!courtDecision) {
+      missingRequirements.push('courtDecision');
+    }
+    if (!validatorLink) {
+      missingRequirements.push('validatorLink');
+    }
+  }
+
+  const sourceChain = {
+    sourceStamp: requiresStamp ? stampComplete : !adapted || stampComplete,
+    sourceCard: adapted ? sourceCardComplete : false,
+    courtDecision: adapted ? courtDecisionComplete : false,
+    validatorLink: Boolean(validatorLink),
+    requiredFieldsComplete: missingRequirements.length === 0,
+    required: adapted,
+  };
+
+  if (missingRequirements.length > 0) {
+    return {
+      status: SOURCE_STATUSES.BLOCKED,
+      releaseBlocking: true,
+      releaseEvidenceAllowed,
+      missingRequirements: [...new Set(missingRequirements)],
+      sourceChain,
+      reason: `source chain incomplete for ${effectiveAdaptation}`,
+    };
+  }
+
+  if (adapted) {
+    return {
+      status: SOURCE_STATUSES.PASS,
+      releaseBlocking: false,
+      releaseEvidenceAllowed,
+      missingRequirements: [],
+      sourceChain,
+      reason: 'full source chain present',
+    };
+  }
+
+  if (classification === SOURCE_CLASSES.REFERENCE_ONLY) {
+    return {
+      status: SOURCE_STATUSES.PARTIAL,
+      releaseBlocking: false,
+      releaseEvidenceAllowed: false,
+      missingRequirements: [],
+      sourceChain,
+      reason: 'reference-only material cannot be release evidence',
+    };
+  }
+
+  if (classification === SOURCE_CLASSES.GOVERNANCE_DOC) {
+    return {
+      status: SOURCE_STATUSES.PARTIAL,
+      releaseBlocking: false,
+      releaseEvidenceAllowed,
+      missingRequirements: [],
+      sourceChain,
+      reason: 'governance influence tracked; source chain not required unless adapted',
+    };
+  }
+
+  return {
+    status: SOURCE_STATUSES.PASS,
+    releaseBlocking: false,
+    releaseEvidenceAllowed,
+    missingRequirements: [],
+    sourceChain,
+    reason: 'Pala-original active file',
+  };
+}
+
+export function summarizeSourceFiles(files) {
+  return files.reduce((summary, file) => {
+    summary.activeFiles += 1;
+    summary.classifiedFiles += 1;
+    if (file.status === SOURCE_STATUSES.BLOCKED) summary.blockedFiles += 1;
+    if (file.status === SOURCE_STATUSES.PARTIAL) summary.partialFiles += 1;
+    if (file.classification === SOURCE_CLASSES.GOVERNANCE_DOC) summary.governanceDocs += 1;
+    if (file.adaptation === SOURCE_CLASSES.LEGACY_ADAPTED || file.classification === SOURCE_CLASSES.LEGACY_ADAPTED) summary.legacyAdapted += 1;
+    if (file.adaptation === SOURCE_CLASSES.OSS_ADAPTED || file.classification === SOURCE_CLASSES.OSS_ADAPTED) summary.ossAdapted += 1;
+    if (file.classification === SOURCE_CLASSES.PALA_ORIGINAL) summary.palaOriginal += 1;
+    if (file.classification === SOURCE_CLASSES.REFERENCE_ONLY) summary.referenceOnly += 1;
+    return summary;
+  }, {
+    activeFiles: 0,
+    classifiedFiles: 0,
+    blockedFiles: 0,
+    partialFiles: 0,
+    governanceDocs: 0,
+    legacyAdapted: 0,
+    ossAdapted: 0,
+    palaOriginal: 0,
+    referenceOnly: 0,
+  });
+}
+
+export function buildSourceStampGate(files, summary) {
+  if (summary.activeFiles === 0) {
+    return {
+      status: SOURCE_STATUSES.NOT_AVAILABLE_WITH_REASON,
+      reasons: ['no active source-court files found in configured scope'],
+    };
+  }
+
+  const blocked = files.filter((file) => file.status === SOURCE_STATUSES.BLOCKED);
+  if (blocked.length > 0) {
+    return {
+      status: SOURCE_STATUSES.BLOCKED,
+      reasons: blocked.slice(0, 20).map((file) => `${file.path}: ${file.reason}`),
+    };
+  }
+
+  if (summary.partialFiles > 0) {
+    return {
+      status: SOURCE_STATUSES.PARTIAL,
+      reasons: ['non-release-blocking governance/reference files need audit tracking'],
+    };
+  }
+
+  return {
+    status: SOURCE_STATUSES.PASS,
+    reasons: ['all active source-court files are classified and no adapted chain is missing'],
+  };
+}
+
+export function sanitizeSourceCourtAudit(audit) {
+  return {
+    status: audit.status,
+    summary: audit.summary,
+    sourceStampGate: audit.sourceStampGate,
+    legacyBoundary: audit.legacyBoundary ?? buildLegacyBoundary({ legacyMode: LEGACY_MODE_DISABLED }),
+  };
+}
+
+export async function buildSourceCourtAudit({
+  rootDir = process.cwd(),
+  sourceCards = [],
+  courtDecisions = null,
+  legacyMode = LEGACY_MODE_DISABLED,
+} = {}) {
+  const resolvedRoot = path.resolve(rootDir);
+  const activeFiles = await discoverActiveFiles(resolvedRoot);
+  const legacyHash = await buildLegacyHashIndex(resolvedRoot, { legacyMode });
+  const legacyHashIndex = legacyHash.index;
+  const decisions = courtDecisions ?? await readDefaultCourtDecisions(resolvedRoot);
+  const files = [];
+
+  for (const filePath of activeFiles) {
+    const relativePath = relativeTo(resolvedRoot, filePath);
+    if (isExcludedPath(relativePath)) {
+      continue;
+    }
+
+    let content = '';
+    try {
+      content = await fs.readFile(filePath, 'utf8');
+    } catch {
+      files.push({
+        path: relativePath,
+        classification: SOURCE_CLASSES.PALA_ORIGINAL,
+        adaptation: null,
+        status: SOURCE_STATUSES.NOT_AVAILABLE_WITH_REASON,
+        reason: 'file could not be read as utf8',
+        releaseBlocking: false,
+        releaseEvidenceAllowed: false,
+        missingRequirements: [],
+        legacyMatches: [],
+        sourceStamp: { present: false, fields: {}, missingFields: REQUIRED_STAMP_FIELDS, complete: false },
+        sourceChain: {
+          sourceStamp: false,
+          sourceCard: false,
+          courtDecision: false,
+          validatorLink: false,
+          requiredFieldsComplete: false,
+          required: false,
+        },
+      });
+      continue;
+    }
+
+    const contentHash = hashContent(content);
+    const legacyMatches = legacyHashIndex.get(contentHash) ?? [];
+    const stamp = parseSourceStamp(content);
+    const classification = classifyFile({ relativePath, content, legacyMatches, stamp });
+    const sourceChainRequired = Boolean(classification.adaptation)
+      || classification.classification === SOURCE_CLASSES.LEGACY_ADAPTED
+      || classification.classification === SOURCE_CLASSES.OSS_ADAPTED;
+    const sourceCard = sourceChainRequired ? findMatchingSourceCard(sourceCards, { stamp, legacyMatches }) : null;
+    const courtDecision = sourceChainRequired ? findMatchingCourtDecision(decisions, { stamp, legacyMatches }) : null;
+    const validatorLink = buildValidatorLink(relativePath, contentHash);
+    const verdict = validateFileChain({
+      classification: classification.classification,
+      adaptation: classification.adaptation,
+      relativePath,
+      stamp,
+      sourceCard,
+      courtDecision,
+      validatorLink,
+    });
+
+    files.push({
+      path: relativePath,
+      classification: classification.classification,
+      adaptation: classification.adaptation,
+      governanceDoc: classification.governanceDoc,
+      status: verdict.status,
+      reason: verdict.reason,
+      releaseBlocking: verdict.releaseBlocking,
+      releaseEvidenceAllowed: verdict.releaseEvidenceAllowed,
+      missingRequirements: verdict.missingRequirements,
+      legacyMatches,
+      validatorLink,
+      sourceStamp: {
+        present: stamp.present,
+        fields: stamp.fields,
+        missingFields: stamp.missingFields,
+        complete: stamp.complete,
+      },
+      sourceCard: sourceCard ? {
+        id: sourceCard.id,
+        originRef: sourceCard.originRef,
+        repoFullName: sourceCard.repoFullName,
+        decision: sourceCard.decision,
+        fieldsComplete: sourceCardFieldsComplete(sourceCard),
+      } : null,
+      courtDecision: courtDecision ? {
+        sourceRef: courtDecision.sourceRef,
+        decision: courtDecision.decision,
+        category: courtDecision.category,
+      } : null,
+      sourceChain: verdict.sourceChain,
+    });
+  }
+
+  const summary = summarizeSourceFiles(files);
+  const sourceStampGate = buildSourceStampGate(files, summary);
+
+  return {
+    status: sourceStampGate.status,
+    summary,
+    files,
+    legacyBoundary: legacyHash.boundary,
+    sourceStampGate,
+  };
+}
