+      || classification.classification === SOURCE_CLASSES.LEGACY_ADAPTED
+      || classification.classification === SOURCE_CLASSES.OSS_ADAPTED;
+    const sourceCard = sourceChainRequired ? findMatchingSourceCard(sourceCards, { stamp, legacyMatches }) : null;
+    const courtDecision = sourceChainRequired ? findMatchingCourtDecision(decisions, { stamp, legacyMatches }) : null;
