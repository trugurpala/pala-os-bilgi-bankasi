+        path: relativePath,
+        classification: SOURCE_CLASSES.PALA_ORIGINAL,
+        adaptation: null,
+        status: SOURCE_STATUSES.NOT_AVAILABLE_WITH_REASON,
+        reason: 'file could not be read as utf8',
+        releaseBlocking: false,
+        releaseEvidenceAllowed: false,
+        missingRequirements: [],
+        legacyMatches: [],
+        sourceStamp: { present: false, fields: {}, missingFields: REQUIRED_STAMP_FIELDS, complete: false },
+        sourceChain: {
+          sourceStamp: false,
+          sourceCard: false,
+          courtDecision: false,
+          validatorLink: false,
+          requiredFieldsComplete: false,
+          required: false,
+        },
+      });
+      continue;
+    }
