+    if (file.classification === SOURCE_CLASSES.GOVERNANCE_DOC) summary.governanceDocs += 1;
+    if (file.adaptation === SOURCE_CLASSES.LEGACY_ADAPTED || file.classification === SOURCE_CLASSES.LEGACY_ADAPTED) summary.legacyAdapted += 1;
+    if (file.adaptation === SOURCE_CLASSES.OSS_ADAPTED || file.classification === SOURCE_CLASSES.OSS_ADAPTED) summary.ossAdapted += 1;
