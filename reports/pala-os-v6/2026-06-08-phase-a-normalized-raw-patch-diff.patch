+  status,
+  dataSource,
+  evidenceSource,
+  fallbackState,
+  passCondition,
+  truthRisk,
+  statusMapping,
+  evidencePresent = false,
+  estimated = false,
+}) {
+  return {
+    id,
+    panel: panelName,
+    status: normalizeTruthStatus(status),
+    dataSource,
+    evidenceSource,
+    fallbackState,
+    passCondition,
+    truthRisk,
+    statusMapping,
+    evidencePresent: Boolean(evidencePresent),
+    estimated: Boolean(estimated),
