+  if (classification === SOURCE_CLASSES.REFERENCE_ONLY) {
+    return {
+      status: SOURCE_STATUSES.PARTIAL,
+      releaseBlocking: false,
+      releaseEvidenceAllowed: false,
+      missingRequirements: [],
+      sourceChain,
