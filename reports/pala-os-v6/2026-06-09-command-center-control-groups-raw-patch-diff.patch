+      'iso-27017',
+      'cis-docker-benchmark',
+      'cis-kubernetes-benchmark',
+      'cis-linux-benchmark',
+      'owasp-docker-top-10',
+      'docker-least-privilege',
+      'kubernetes-pod-security-standards',
+    ],
+  },
+  {
+    id: 'threat-vulnerability-intel',
+    name: 'Threat & Vulnerability Intel',
+    surface: 'Pala Court',
+    ownerQuestion: 'Do known attack techniques and vulnerability signals change the release decision?',
+    evidenceRule: 'Threat and vulnerability signals should feed court blockers instead of living as passive labels.',
+    standardIds: [
+      'mitre-attack',
+      'mitre-cwe',
+      'mitre-capec',
+      'cve',
+      'cvss',
+      'epss',
+      'cisa-kev',
+    ],
+  },
+  {
+    id: 'pala-operating-law',
+    name: 'Pala Operating Law',
+    surface: 'Pala Court',
+    ownerQuestion: 'Did Pala keep no-fake-done, owner approval, GitHub boundary, and local evidence intact?',
+    evidenceRule: 'Pala law blocks fake green states: no evidence, no pass; no owner approval, no push or release.',
+    standardIds: [
+      'cis-controls',
+      'cis-github-benchmark',
+      'github-oidc-least-privilege',
+      'pala-no-fake-done-ledger-law',
+    ],
+  },
+];
+
+export function controlGroupsSeed() {
+  return {
+    version: CONTROL_GROUPS_VERSION,
+    productName: COMMAND_CENTER_NAME,
+    headline: COMMAND_CENTER_HEADLINE,
+    rule: 'External tools and ideas start as reference. Source-card, risk, layer, evidence, Pala Court, and owner approval decide whether they move further.',
+    surfaces: [
+      'Pala Court',
+      'Pala Evidence Ledger',
+      'Pala World Standards Atlas',
+      'Pala Agent Control Radar',
+      'Pala Skill Registry',
+      'Pala Action Queue',
+    ],
+    groups: CONTROL_GROUP_DEFINITIONS,
+  };
+}
+
+export async function ensureControlGroupsCatalog() {
+  await fs.writeFile(CONTROL_GROUPS_PATH, `${JSON.stringify(controlGroupsSeed(), null, 2)}\n`, 'utf8');
+}
+
+export async function loadControlGroupsCatalog() {
+  try {
+    const content = await fs.readFile(CONTROL_GROUPS_PATH, 'utf8');
+    const parsed = JSON.parse(content);
+    return {
+      ...controlGroupsSeed(),
+      ...parsed,
+      groups: Array.isArray(parsed.groups) ? parsed.groups : CONTROL_GROUP_DEFINITIONS,
+    };
+  } catch {
+    return controlGroupsSeed();
+  }
+}
+
+function countStandards(standards) {
+  return standards.reduce((counts, standard) => {
+    counts.total += 1;
+    if (standard.policyState === 'required') counts.required += 1;
+    if (standard.policyState === 'recommended') counts.recommended += 1;
+    if (standard.status === 'blocked') counts.blocked += 1;
+    if (standard.satisfied) counts.satisfied += 1;
+    if (standard.status === 'not_applicable_with_reason') counts.notApplicable += 1;
+    counts.evidence += Number(standard.evidenceCount ?? 0);
+    return counts;
+  }, {
+    total: 0,
+    required: 0,
+    recommended: 0,
+    blocked: 0,
+    satisfied: 0,
+    notApplicable: 0,
+    evidence: 0,
+  });
+}
+
+function statusForGroup(counts) {
+  if (counts.blocked > 0) return 'blocked';
+  if (counts.satisfied > 0) return 'evidence';
+  return 'pending';
+}
+
+function firstMissingRequired(standards) {
+  return standards.find((standard) => standard.status === 'blocked' && standard.policyState === 'required') ?? null;
+}
+
+export function buildControlGroups(evaluatedStandards, catalog = controlGroupsSeed()) {
+  const standardsById = new Map(evaluatedStandards.map((standard) => [standard.id, standard]));
+
+  return catalog.groups.map((group) => {
+    const standards = group.standardIds
+      .map((standardId) => standardsById.get(standardId))
+      .filter(Boolean);
+    const counts = countStandards(standards);
+    const missing = firstMissingRequired(standards);
+
+    return {
+      ...group,
+      ...counts,
+      status: statusForGroup(counts),
+      primaryAction: missing
+        ? `Add evidence for ${missing.title}`
+        : counts.evidence > 0
+          ? 'Review evidence freshness'
+          : 'Collect first evidence item',
+      primaryStandardId: missing?.id ?? standards[0]?.id ?? null,
+      standards: standards.map((standard) => ({
+        id: standard.id,
+        title: standard.title,
+        family: standard.family,
+        policyState: standard.policyState,
+        status: standard.status,
+        evidenceCount: standard.evidenceCount,
+        reason: standard.reason,
+      })),
+    };
+  });
+}
+
+export function summarizeControlGroups(groups) {
+  return groups.reduce((summary, group) => {
+    summary.totalGroups += 1;
+    summary.totalStandards += group.total;
+    summary.required += group.required;
+    summary.recommended += group.recommended;
+    summary.blocked += group.blocked;
+    summary.satisfied += group.satisfied;
+    summary.evidence += group.evidence;
+    if (group.blocked > 0) summary.blockedGroups += 1;
+    if (group.status === 'evidence') summary.evidenceGroups += 1;
+    return summary;
+  }, {
+    productName: COMMAND_CENTER_NAME,
+    headline: COMMAND_CENTER_HEADLINE,
+    totalGroups: 0,
+    totalStandards: 0,
+    required: 0,
+    recommended: 0,
+    blocked: 0,
+    satisfied: 0,
+    evidence: 0,
+    blockedGroups: 0,
+    evidenceGroups: 0,
+  });
+}
+
+export function buildReleasePosture({ summary, court, sourceCards, ledger, github }) {
+  const blockedRequired = summary.byStatus.blocked ?? 0;
+  const sourceCardCount = sourceCards.length;
+  const ledgerCount = ledger.length;
+  const reasons = [];
+
+  if (blockedRequired > 0) reasons.push(`${blockedRequired} required standards still need evidence`);
+  if (sourceCardCount === 0) reasons.push('source-card gate has no approved reference evidence');
+  if (ledgerCount === 0) reasons.push('evidence ledger has no local proof records');
+  if (!github.configured) reasons.push('GitHub bridge is not configured for operational source-of-record checks');
+  reasons.push('owner approval is required for push and release');
+
+  return {
+    productName: COMMAND_CENTER_NAME,
+    courtName: 'Pala Court',
+    ledgerName: 'Pala Evidence Ledger',
+    headline: COMMAND_CENTER_HEADLINE,
+    decision: court.decision,
+    status: court.decision === 'RELEASE_BLOCKED' || blockedRequired > 0 ? 'blocked' : 'owner_review',
+    releaseAllowed: false,
+    ownerApprovalRequired: true,
+    ownerApprovalState: 'required_for_push_release',
+    blockedRequired,
+    sourceCardCount,
+    ledgerCount,
+    githubConfigured: Boolean(github.configured),
+    reasons,
+    primaryMessage: reasons[0] ?? 'Court can move only after owner approval is recorded.',
+  };
+}
+
+export function buildActionQueue({
+  controlGroups,
+  releasePosture,
+  sourceCards,
+  github,
+  marketRadarSummary,
+  jobRuns,
+}) {
+  const queue = [];
+  const push = (item) => {
+    queue.push({
+      priority: queue.length + 1,
+      ...item,
+    });
+  };
+
+  if (releasePosture.status === 'blocked') {
+    push({
+      title: 'Pala Court release blocker',
+      layer: 'Pala Court',
+      status: 'blocked',
+      detail: releasePosture.primaryMessage,
+      evidenceCommand: 'sak court',
+    });
+  }
+
+  controlGroups
+    .filter((group) => group.blocked > 0)
+    .sort((left, right) => right.blocked - left.blocked || left.name.localeCompare(right.name))
+    .slice(0, 2)
+    .forEach((group) => {
+      push({
+        title: `${group.name} evidence gap`,
+        layer: group.surface,
+        status: 'blocked',
+        detail: `${group.blocked} required standards need evidence. Next: ${group.primaryAction}.`,
+        evidenceCommand: group.primaryStandardId
+          ? `sak evidence add --standard ${group.primaryStandardId} --detail "..."`
+          : 'sak status',
+      });
+    });
+
+  if (sourceCards.length === 0) {
+    push({
+      title: 'Source-card gate is empty',
+      layer: 'Pala Evidence Ledger',
+      status: 'partial',
+      detail: 'External references are still catalog entries, not source-carded proof.',
+      evidenceCommand: 'sak ingest --repo owner/name --decision REFERENCE_ONLY --layer reference --risk low --evidence-uri URL',
+    });
+  }
+
+  if ((marketRadarSummary.total ?? 0) > (marketRadarSummary.sourceCarded ?? 0)) {
+    push({
+      title: 'Market radar references need source cards',
+      layer: 'Pala Agent Control Radar',
+      status: 'partial',
+      detail: `${marketRadarSummary.sourceCarded ?? 0}/${marketRadarSummary.total ?? 0} market references are source-carded.`,
+      evidenceCommand: 'sak ingest --repo owner/name --decision REFERENCE_ONLY --layer reference --risk low --evidence-uri URL',
+    });
+  }
+
+  if (!github.configured) {
+    push({
+      title: 'GitHub source-of-record check',
+      layer: 'Pala Court',
+      status: 'owner_controlled',
+      detail: github.reason,
+      evidenceCommand: 'sak github sync',
+    });
+  }
+
+  if (jobRuns.length === 0) {
+    push({
+      title: 'Watcher evidence is empty',
+      layer: 'Pala Evidence Ledger',
+      status: 'partial',
+      detail: 'Cron watchers have not recorded this workspace posture yet.',
+      evidenceCommand: 'sak cron run',
+    });
+  }
+
+  if (queue.length < 3) {
+    push({
+      title: 'Owner release review',
+      layer: 'Pala Court',
+      status: 'owner_controlled',
+      detail: 'Even with green evidence, push and release remain owner-controlled.',
+      evidenceCommand: 'sak audit',
+    });
+  }
+
+  return queue.slice(0, 6);
+}
